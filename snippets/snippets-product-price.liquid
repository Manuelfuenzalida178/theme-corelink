{% comment %}
  Renders product pricing with discount badge
  
  Usage:
  {% render 'product-price', variant: current_variant %}
{% endcomment %}

{%- liquid
  assign variant = variant | default: product.selected_or_first_available_variant
  assign compare_at_price = variant.compare_at_price
  assign price = variant.price
  assign available = variant.available
  
  if compare_at_price and compare_at_price > price
    assign on_sale = true
    assign discount_percentage = 65
  else
    assign on_sale = false
  endif
-%}

<style>
  .product-price-container {
    margin: 24px 0;
  }
  
  .product-price__compare {
    font-size: 18px;
    color: #9ca3af;
    text-decoration: line-through;
    line-height: 1.2;
    font-weight: 400;
    display: block;
    margin-bottom: 4px;
  }
  
  .product-price__main-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .product-price__current {
    font-size: 25px;
    font-weight: 500;
    color:#000000;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  
  .product-price__discount-badge {
    background: #dff519;
    color: black;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1.2;
  }
  
  .product-price__unavailable {
    font-size: 16px;
    color: #999;
  }
  
  @media screen and (max-width: 749px) {
    .product-price__current {
      font-size: 36px;
    }
    
    .product-price__compare {
      font-size: 14px;
    }
    
    .product-price__discount-badge {
      font-size: 10px;
      padding: 5px 10px;
    }
  }
</style>

{% if available == false %}
  <div class="product-price__unavailable">
    {{ 'products.product.sold_out' | t }}
  </div>
{% else %}
  <div class="product-price-container">
    {% if on_sale %}
      <span class="product-price__compare">
        {{ compare_at_price | money }}
      </span>
    {% endif %}
    
    <div class="product-price__main-row">
      <span class="product-price__current" data-product-price>
        {{ price | money }}
      </span>
      
      {% if on_sale %}
        <span class="product-price__discount-badge">
          {{ discount_percentage }}% DE DESCUENTO
        </span>
      {% endif %}
    </div>
  </div>
{% endif %}