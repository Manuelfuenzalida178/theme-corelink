<script>
(function() {
  'use strict';
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }
  
  function initCarousel() {
    var currentIndex = 0;
    var autoPlayEnabled = true;
    var autoPlayTimer = null;
    var storiesScroll = document.getElementById('storiesScroll');
    var prevButton = document.getElementById('prevButton');
    var nextButton = document.getElementById('nextButton');
    var cards = document.querySelectorAll('.story-card');
    var dots = document.querySelectorAll('.dot');

    if (!storiesScroll || !prevButton || !nextButton || cards.length === 0) {
      return;
    }

    function stopAutoPlay() {
      autoPlayEnabled = false;
      if (autoPlayTimer) {
        clearInterval(autoPlayTimer);
        autoPlayTimer = null;
      }
    }

    function scrollToStory(index, isAutoPlay) {
      currentIndex = index;
      
      if (!isAutoPlay) {
        stopAutoPlay();
      }
      
      cards.forEach(function(card, i) {
        if (i === index) {
          card.classList.add('active');
        } else {
          card.classList.remove('active');
        }
      });

      dots.forEach(function(dot, i) {
        if (i === index) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });

      var targetCard = cards[index];
      var scrollLeft = targetCard.offsetLeft - (storiesScroll.offsetWidth / 2) + (targetCard.offsetWidth / 2);
      storiesScroll.scrollTo({
        left: scrollLeft,
        behavior: 'smooth'
      });

      prevButton.disabled = index === 0;
      nextButton.disabled = index === cards.length - 1;
    }

    prevButton.addEventListener('click', function() {
      if (currentIndex > 0) {
        scrollToStory(currentIndex - 1, false);
      }
    });

    nextButton.addEventListener('click', function() {
      if (currentIndex < cards.length - 1) {
        scrollToStory(currentIndex + 1, false);
      }
    });

    dots.forEach(function(dot, index) {
      dot.addEventListener('click', function() {
        scrollToStory(index, false);
      });
    });

    cards.forEach(function(card, index) {
      card.addEventListener('click', function() {
        scrollToStory(index, false);
      });
    });

    function startAutoPlay() {
      if (!autoPlayEnabled) return;
      
      autoPlayTimer = setInterval(function() {
        if (!autoPlayEnabled) return;
        
        var nextIndex = currentIndex < cards.length - 1 ? currentIndex + 1 : 0;
        scrollToStory(nextIndex, true);
      }, 3500);
    }

    scrollToStory(0, true);
    startAutoPlay();
  }
})();
</script>
