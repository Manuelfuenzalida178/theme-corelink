{% comment %}
  SNIPPET: Customer Testimonials
  Uso: {% include 'customer-testimonials' %}
  
  Para personalizar las imágenes, edita las URLs directamente aquí.
{% endcomment %}

<style>
  .customer-testimonials-custom {
    background-color: #ffffff;
    padding: 0 0 24px;
  }

  .testimonials-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .testimonials-header {
    margin-bottom: 1.25rem;
  }

  .testimonials-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #111827;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .testimonials-subtitle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #4b5563;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .info-icon {
    width: 1rem;
    height: 1rem;
    color: #3b82f6;
    flex-shrink: 0;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .testimonial-image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 135%;
    overflow: hidden;
    border-radius: 12px;
    background-color: #f3f4f6;
  }

  .testimonial-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .testimonial-image-wrapper:hover .testimonial-image {
    transform: scale(1.05);
  }

  @media (max-width: 639px) {
    .testimonials-title {
      font-size: 1.25rem;
    }
    
    .testimonials-subtitle {
      font-size: 0.875rem;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="customer-testimonials-custom">
  <div class="testimonials-container">
    
    <div class="testimonials-header">
      <h2 class="testimonials-title">Recomendado por clientes</h2>
      
      <div class="testimonials-subtitle">
        <svg class="info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <span>Más de 100,000 coches ya lo usan cada día.</span>
      </div>
    </div>

    <div class="testimonials-grid">
      
      <!-- Imagen 1 - EDITA LA URL AQUÍ -->
      <div class="testimonial-image-wrapper">
        <img 
          class="testimonial-image" 
          src="https://cdn.shopify.com/s/files/1/YOUR-STORE/files/testimonial-1.jpg" 
          alt="Cliente satisfecho usando el producto"
          loading="lazy"
        >
      </div>

      <!-- Imagen 2 - EDITA LA URL AQUÍ -->
      <div class="testimonial-image-wrapper">
        <img 
          class="testimonial-image" 
          src="https://cdn.shopify.com/s/files/1/YOUR-STORE/files/testimonial-2.jpg" 
          alt="Cliente mostrando el producto"
          loading="lazy"
        >
      </div>

      <!-- Imagen 3 - EDITA LA URL AQUÍ -->
      <div class="testimonial-image-wrapper">
        <img 
          class="testimonial-image" 
          src="https://cdn.shopify.com/s/files/1/YOUR-STORE/files/testimonial-3.jpg" 
          alt="Producto instalado en el coche"
          loading="lazy"
        >
      </div>

      <!-- OPCIONAL: Agrega más imágenes copiando este bloque
      <div class="testimonial-image-wrapper">
        <img 
          class="testimonial-image" 
          src="https://cdn.shopify.com/s/files/1/YOUR-STORE/files/testimonial-4.jpg" 
          alt="Descripción de la imagen"
          loading="lazy"
        >
      </div>
      -->

    </div>

  </div>
</div>
