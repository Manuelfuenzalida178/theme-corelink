{"sections":{"main":{"type":"page-template","disabled":true,"settings":{}},"custom_personalizado_Nizfg8":{"type":"custom-personalizado","name":"Liquid Personalizado","settings":{"layout":"full_width","color_scheme":"1","background_color":"#000000","text_alignment":"left","custom_liquid":"<div class=\"section   section-full bg-custom\" style=\"--background: 0 0 0;\">\n    <div id=\"intake-onboarding-wrapper\">\n  <style>\n    \/* PROGRESS BAR BASE STYLES *\/\n    .progress-container {\n      position: fixed;\n      top: 59.64px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 100%;\n      max-width: 400px;\n      height: 4px;\n      background: #333;\n      z-index: 1;\n    }\n    .progress-bar {\n      width: 0;\n      height: 100%;\n      background: #00fea9;\n      transition: width 0.8s ease;\n    }\n    @media (min-width: 700px) {\n      .progress-container {\n        top: 101.5px;\n        width: 700px;\n      }\n    }\n\n    \/* Wrapper *\/\n    \/* Desktop-only extra copy for Step 3 *\/\n    .desktop-only { display: none; }\n    \/* Desktop-only extra copy for Step 3 *\/\n    .desktop-only { display: none; }\n\n    \/* Wrapper *\/\n    #intake-onboarding-wrapper {\n      position: relative;\n      max-width: 400px;\n      margin: 0 auto;\n      \/* allow wrapper to expand and not trap page scroll *\/\n      height: auto;\n      min-height: 100vh;\n      background: black;\n      color: white;\n      font-family: 'Inter', sans-serif;\n      overflow: visible;\n    }\n    \/* Progress Bar *\/\n    .progress-container {\n      position: fixed;\n      top: 59.64px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 100%;\n      max-width: 400px;\n      height: 4px;\n      background: #333;\n      z-index: 1;\n    }\n    @media (min-width: 700px) {\n      .progress-container {\n        top: 101.5px;\n        max-width: 1920px;\n      }\n    }\n    \/* Desktop: progress bar offset under larger header *\/\n    \n    \n    \/* Shift progress bar under larger desktop header *\/\n    \n    @media (min-width: 800px) {\n      \/* Step 0: left-align Continue button on desktop *\/\n      #step-0 .step-buttons {\n        justify-content: flex-start !important;\n        margin-left: -1rem !important;\n      }\n      .onboarding-step#step-3 .apply-grid {\n        align-self: center;\n      }\n    \/* Wrapper full screen *\/\n    #intake-onboarding-wrapper {\n      max-width: 800px;\n      height: 100vh;\n    }\n    \/* Container adjusts to full height *\/\n    #intake-onboarding {\n      height: 100%;\n      overflow-y: hidden;\n    }\n    \/* Grid layout: left text, right media, centered vertically *\/\n    .onboarding-step {\n      position: relative;\n      height: 100%;\n      display: grid;\n      grid-template-columns: 1fr auto;\n      grid-template-rows: auto auto auto auto;\n      justify-items: start;\n      align-content: center;\n        align-items: center;\n      row-gap: 0.5rem;\n      column-gap: 2rem;\n      padding: 1rem;\n    }\n    \/* Media on right spans all rows *\/\n    .onboarding-step .media {\n        grid-column: 2;\n        grid-row: 1 \/ -1;\n        width: 250px;\n        height: 250px;\n        align-self: center;\n      }\n    \/* Text elements in left column *\/\n    .onboarding-step .step-label { grid-column: 1; grid-row: 1; margin-bottom: 0; }\n    .onboarding-step h2         { grid-column: 1; grid-row: 2; font-size: 2rem; margin: 0; }\n    .onboarding-step p          { grid-column: 1; grid-row: 3; font-size: 1.125rem; margin: 0; }\n    .onboarding-step .step-buttons { grid-column: 1; grid-row: 4; justify-self: start; margin: 0; }\n    \/* Step 3 grid media enlarge *\/\n    .apply-grid { margin: 1rem 0; }\n    .apply-grid img {\n        width: 300px;\n        height: 300px;\n        object-fit: cover;\n        margin: 0 auto;\n      }\n      \/* Desktop-only: smaller captions under GIFs in Step 3 *\/\n      @media (min-width: 800px) {\n        .onboarding-step#step-3 .apply-grid p {\n          font-size: 0.875rem;\n        }\n      }\n    \/* Step 3 desktop-specific column tweak *\/\n    .onboarding-step#step-3 {\n      grid-template-columns: 1.5fr auto;\n    }\n    .onboarding-step#step-3 .apply-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 200px);\n      justify-self: center;\n      align-self: center;\n    }\n  }\n    \/* Tighter label-title spacing *\/\n    .onboarding-step .step-label {\n      margin-bottom: 0;\n    }\n    .onboarding-step h2 {\n      font-size: 2rem;\n      margin-top: 0;\n      margin-bottom: 0.5rem;\n    }\n    .onboarding-step p {\n      font-size: .9rem;\n    }\n    .media {\n      width: 250px;\n      height: 250px;\n    }\n  }\n    }\n    .progress-bar {\n      width: 0;\n      height: 100%;\n      background: #00fea9;\n      transition: width 0.8s ease;\n    }\n    \/* Container *\/\n    #intake-onboarding {\n      position: relative;\n      padding-top: 16px;\n      \/* ensure bottom padding so buttons never get cut off *\/\n      padding-bottom: 4rem;\n      \/* allow content to flow—use page scroll *\/\n      height: auto;\n      overflow-y: visible;\n      -webkit-overflow-scrolling: auto;\n    }\n    \/* Steps *\/\n    .onboarding-step#step-0 {\n      position: relative !important;\n      height: auto !important;\n    }\n    .onboarding-step {\n      position: absolute;\n      top: 0px; left: 0; right: 0; bottom: 0;\n      display: flex;\n      flex-direction: column;\n      padding: 1.5rem 1rem;\n      opacity: 0;\n      pointer-events: none;\n      transform: translateY(20px);\n      transition: opacity 0.8s ease, transform 0.8s ease;\n    }\n    .onboarding-step.active {\n      opacity: 1;\n      pointer-events: auto;\n      transform: translateY(0);\n    }\n    \/* Step label *\/\n    .step-label {\n      color: #737373;\n      opacity: 0;\n      transform: translateY(20px);\n      transition: opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;\n    }\n    .onboarding-step.active .step-label {\n      opacity: 1;\n      transform: translateY(0);\n    }\n    \/* Headings *\/\n    .onboarding-step h2 {\n      margin: 0.5rem 0;\n      font-size: 1.5rem;\n      font-weight: 500;\n      text-align: left;\n      opacity: 0;\n      transform: translateY(20px);\n      transition: opacity 0.8s ease 0.4s, transform 0.8s ease 0.4s;\n    }\n    .onboarding-step.active h2 {\n      opacity: 1;\n      transform: translateY(0);\n    }\n    \/* Paragraphs *\/\n    .onboarding-step p {\n      margin: 0.5rem 0 1.5rem;\n      text-align: left;\n      opacity: 0;\n      transform: translateY(20px);\n      transition: opacity 0.8s ease 0.6s, transform 0.8s ease 0.6s;\n    }\n    .onboarding-step.active p {\n      opacity: 1;\n      transform: translateY(0);\n    }\n    \/* Media (video\/image) *\/\n    .media {\n      width: 100%;\n      height: auto;\n      opacity: 0;\n      transform: translateY(20px);\n      transition: opacity 0.8s ease 0.8s, transform 0.8s ease 0.8s;\n      object-fit: cover;\n    }\n    .onboarding-step.active .media {\n      opacity: 1;\n      transform: translateY(0);\n    }\n    \/* Buttons container *\/\n    .step-buttons {\n      margin-top: auto;\n      margin-bottom: 3rem;\n      display: flex;\n      gap: 0.5rem;\n      justify-content: center;\n      opacity: 0;\n      transform: translateY(20px);\n      transition: opacity 0.8s ease 1.0s, transform 0.8s ease 1.0s;\n    }\n    .onboarding-step.active .step-buttons {\n      opacity: 1;\n      transform: translateY(0);\n    }\n    .step-buttons button {\n      white-space: nowrap;\n      background: #00fea9;\n      color: black;\n      border: none;\n      padding: 0.75rem 1.5rem;\n      border-radius: 999px;\n      font-size: 1rem;\n      cursor: pointer;\n      display: flex;\n      align-items: center;\n      gap: 0.5rem;\n    }\n    .step-buttons button.secondary {\n      background: #333;\n      color: white;\n    }\n    \/* Step 3 grid cascade *\/\n    .apply-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 1rem;\n      margin: 1rem 0;\n    }\n    .apply-grid > div {\n      opacity: 0;\n      transform: translateY(20px);\n      transition: opacity 0.8s ease, transform 0.8s ease;\n    }\n    #step-3.active .apply-grid > div:nth-child(1) { transition-delay: 0.8s; }\n    #step-3.active .apply-grid > div:nth-child(2) { transition-delay: 1.0s; }\n    #step-3.active .apply-grid > div:nth-child(3) { transition-delay: 1.2s; }\n    #step-3.active .apply-grid > div:nth-child(4) { transition-delay: 1.4s; }\n    #step-3.active .apply-grid > div { opacity: 1; transform: translateY(0); }\n    .apply-grid img {\n      width: 120px;\n      height: 120px;\n      object-fit: cover;\n      margin: 0 auto;\n    }\n    \/* Feedback row cascade *\/\n    .onboarding-step#step-4 .feedback-row {\n      position: absolute;\n      top: 50%; left: 50%;\n      transform: translateY(20px) translate(-50%, -50%);\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 1rem;\n      text-align: left;\n      opacity: 0;\n      transition: opacity 0.8s ease 1.0s, transform 0.8s ease 1.0s;\n      \/* Allow feedback text to span wider *\/\n      width: calc(100% - 4rem);\n      max-width: 400px;\n      padding: 0 1rem;\n    }\n    .onboarding-step#step-4.active .feedback-row {\n      opacity: 1;\n      transform: translate(-50%, -50%);\n    }\n    \/* Continue button full width and bottom-positioned *\/\n    \n    #step-0 .step-buttons #continue-btn {\n      width: auto;\n      margin: 0 1rem;\n      justify-content: center;\n    }\n    \/* Modal overlay *\/\n    .modal-overlay {\n      position: fixed; top: 0; left: 0;\n      width: 100vw; height: 100vh;\n      background: rgba(0,0,0,0.8);\n      display: flex; justify-content: center; align-items: center;\n      transform: translateY(100%);\n      transition: transform 0.4s ease;\n      z-index: 2000;\n    }\n    .modal-overlay.active { transform: translateY(0); }\n    .modal-content {\n      position: relative; width: 100%; max-width: 400px;\n      overflow: hidden; border-radius: 15px;\n    }\n    .modal-content video {\n      width: 100%; height: auto; box-sizing: border-box;\n    }\n    .modal-close {\n      position: absolute;\n      top: 1rem;\n      right: 1rem;\n      background: white;\n      border: none;\n      border-radius: 50%;\n      width: 32px;\n      height: 32px;\n      font-size: 1.2rem;\n      cursor: pointer;\n      z-index: 10;\n      color: black; \/* ensure the × icon is visible *\/\n      display: flex; \/* center the icon *\/\n      justify-content: center;\n      align-items: center;\n    }\n    .overlay-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);\n      color: white; font-size: 3rem; opacity: 0; pointer-events: none;\n      transition: opacity 0.3s ease;\n    }\n    .overlay-icon.show { opacity: 1; }\n    \/* Full bleed media override for Step 0 *\/\n    \/* ensure Step 0 fills viewport for bottom positioning *\/\n    \n    \n    \/* Position Step 0 continue button at bottom *\/    \/* Desktop layout enhancements *\/\n  @media (min-width: 800px) {\n    #intake-onboarding-wrapper {\n      max-width: 800px;\npadding-top: 100px;\n    }\n    .onboarding-step {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 2rem;\n      align-items: center;\n      text-align: left;\n    }\n    .onboarding-step h2 {\n      font-size: 2rem;\n    }\n    .onboarding-step p {\n      font-size: 1.125rem;\n    }\n    .media {\n      width: 250px;\n      height: 250px;\n    }\n  }\n  \/* Desktop layout enhancements for left-text, right-media *\/\n  @media (min-width: 800px) {\n    .onboarding-step {\n      display: grid;\n      grid-template-columns: 1fr auto;\n      align-items: center;\n      gap: 2rem;\n    }\n    .onboarding-step .media {\n      grid-column: 2;\n      grid-row: 1 \/ -1;\n    }\n    .onboarding-step .step-label,\n    .onboarding-step h2,\n    .onboarding-step p,\n    .onboarding-step .step-buttons {\n      grid-column: 1;\n    }\n  }\n  \/* Desktop override: enlarge step 0-2 media *\/\n  @media (min-width: 800px) {\n    #step-0 .media,\n    #step-1 .media,\n    #step-2 .media {\n      width: 350px;\n      height: 350px;\n    }\n  }\n  \/* Force two-column layout for Step 3 on desktop *\/\n  @media (min-width: 800px) {\n    .onboarding-step#step-3 {\n      grid-template-columns: 1fr auto !important;\n    }\n    .onboarding-step#step-3 .apply-grid {\n      grid-column: 2 !important;\n      grid-row: 1 \/ span 4 !important;\n      justify-self: center !important;\n      align-self: center !important;\n      display: grid !important;\n      grid-template-columns: repeat(2, 200px) !important;\n      gap: 1rem !important;\n    }\n  }\n  \/* Force tight vertical stack for left column on desktop *\/\n  @media (min-width: 800px) {\n    .onboarding-step {\n      align-content: center !important;\n      row-gap: 0.25rem !important;\n      padding-top: 0.5rem !important;\n      padding-bottom: 0.5rem !important;\n    }\n    .onboarding-step .step-label,\n    .onboarding-step h2,\n    .onboarding-step p,\n    .onboarding-step .step-buttons {\n      margin: 0 !important;\n    }\n  }\n  \/* Step 0 spacing adjustments *\/\n  .onboarding-step#step-0 {\n    padding-top: 2rem; \/* push content lower *\/\n  }\n  #step-0 h2 {\n    margin-bottom: 1rem; \/* more space below title *\/\n  }\n  #step-0 p {\n    margin-bottom: 1.5rem; \/* more space below paragraph *\/\n  }\n  @media (min-width: 800px) {\n    \/* Desktop-specific Step 0 tweaks *\/\n    .onboarding-step#step-0 {\n      row-gap: 1rem !important; \/* increase grid row gap *\/\n      padding-top: 2rem !important;\n    }\n  }\n  \/* Desktop: increase vertical spacing in left column and push Step 0 video down *\/\n  @media (min-width: 800px) {\n    .onboarding-step {\n      row-gap: 1rem !important;\n      padding-top: 2rem !important;\n      padding-bottom: 2rem !important;\n    }\n    #step-0 .media {\n      margin-top: 2rem !important;\n    }\n  }\n  \/* Desktop-only padding below Continue button on Step 0 *\/\n  @media (min-width: 800px) {\n    #step-0 .step-buttons {\n      margin-bottom: 100px !important;\n    }\n  }\n  \/* Step 3: extra column gap on desktop *\/\n  @media (min-width: 800px) {\n    .onboarding-step#step-3 {\n      column-gap: 3rem !important;\n    }\n  }\n  \/* Force two-column layout for Step 3 on desktop *\/\n  @media (min-width: 800px) {\n    .onboarding-step#step-3 {\n      display: grid !important;\n      grid-template-columns: 1fr auto !important;\n      grid-template-rows: auto auto auto auto !important;\n    }\n    .onboarding-step#step-3 .apply-grid {\n      grid-column: 2 !important;\n      grid-row: 1 \/ span 4 !important;\n      align-self: center !important;\n      justify-self: center !important;\n    }\n  }\n  \/* Ensure Step 3 desktop body appears *\/\n  @media (min-width: 700px) {\n    #step-3 .desktop-only {\n      display: block !important;\n    }\n  }\n<\/style>\n\n  <!-- Progress Bar -->\n  <div class=\"progress-container\"><div class=\"progress-bar\" id=\"progress-bar\" style=\"width: 0%;\"><\/div><\/div>\n\n  <!-- Onboarding Steps -->\n  <div id=\"intake-onboarding\">\n    <!-- Step 0 -->\n    <div id=\"step-0\" class=\"onboarding-step active\">\n      <h2><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Empecemos<\/font><\/font><\/h2>\n      <p><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Tres sencillos pasos para una respiración que cambie tu vida.<\/font><\/font><\/p>\n      <video class=\"media\" autoplay=\"\" muted=\"\" loop=\"\" playsinline=\"\" src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/5d376a11fd6144bd88dcced7beb4dfe9.mp4\"><\/video>\n      <div class=\"step-buttons\"><button id=\"continue-btn\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Continuar<\/font><\/font><\/button><\/div>\n    <\/div>\n\n    <!-- Step 1 -->\n    <div id=\"step-1\" class=\"onboarding-step\">\n      <div class=\"step-label\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Paso 1 de 3<\/font><\/font><\/div>\n      <h2><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Prueba de ajuste de Bull Ring<\/font><\/font><\/h2>\n      <p><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">La banda de tamaño perfecto debe tocar la parte exterior de las fosas nasales sin presionarlas ni cerrarlas.<\/font><\/font><\/p>\n      <img class=\"media\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1262\/8823\/files\/Fit_Test_1.gif?v=1750210529\">\n      <div class=\"step-buttons\">\n        <button class=\"secondary\" id=\"back-btn-1\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">←<\/font><\/font><\/button>\n        <button class=\"secondary tutorial-btn\" data-video=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/fa2240d01b434d4caa1b49b45e4f1c8e.mp4\"><span class=\"play-icon\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">▶︎<\/font><\/font><\/span><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Tutorial<\/font><\/font><\/button>\n        <button id=\"next-btn-1\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Próximo paso<\/font><\/font><\/button>\n      <\/div>\n    <\/div>\n\n    <!-- Step 2 -->\n    <div id=\"step-2\" class=\"onboarding-step\">\n      <div class=\"step-label\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Paso 2 de 3<\/font><\/font><\/div>\n      <h2><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Limpia y seca tu nariz<\/font><\/font><\/h2>\n      <p><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Elimine la suciedad y la grasa de la piel con agua y jabón. Deje que la nariz se seque por completo.<\/font><\/font><\/p>\n      <img class=\"media\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1262\/8823\/files\/Clean_and_Dry_1.gif?v=1750210530\">\n      <div class=\"step-buttons\">\n<button class=\"secondary\" id=\"back-btn-2\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">←<\/font><\/font><\/button><button id=\"next-btn-2\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Próximo paso<\/font><\/font><\/button>\n<\/div>\n    <\/div>\n\n    <!-- Step 3 -->\n    <div id=\"step-3\" class=\"onboarding-step\">\n      <div class=\"step-label\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Paso 3 de 3<\/font><\/font><\/div>\n      <h2><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Aplicar pestañas y bandas<\/font><\/font><\/h2>\n      <p class=\"desktop-only\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Con los dedos, aplique una pestaña adhesiva a cada lado de la nariz, justo encima de las fosas nasales.<\/font><\/font><\/p>\n      <div class=\"apply-grid\">\n        <div>\n<img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1262\/8823\/files\/Peel_Tabs_1.gif?v=1750210529\"><p><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Retire con cuidado las pestañas y evite el adhesivo.<\/font><\/font><\/p>\n<\/div>\n        <div>\n<img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1262\/8823\/files\/Place_Tab_1.gif?v=1750210529\"><p><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Coloque las pestañas como se muestra<\/font><\/font><\/p>\n<\/div>\n        <div>\n<img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1262\/8823\/files\/Rub_Tab_1.gif?v=1750210530\"><p><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">¡Frótalo, por qué no!<\/font><\/font><\/p>\n<\/div>\n        <div>\n<img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1262\/8823\/files\/Shark_Fins_1.gif?v=1750210530\"><p><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Aplicar la banda, aletas de tiburón hacia arriba<\/font><\/font><\/p>\n<\/div>\n      <\/div>\n      <div class=\"step-buttons\">\n        <button class=\"secondary\" id=\"back-btn-3\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">←<\/font><\/font><\/button>\n        <button class=\"secondary tutorial-btn\" data-video=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/abcf71c5f2b94867ba67b37e51bc9537.mp4\"><span class=\"play-icon\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">▶︎<\/font><\/font><\/span><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Tutorial<\/font><\/font><\/button>\n        <button id=\"next-btn-3\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Próximo paso<\/font><\/font><\/button>\n      <\/div>\n    <\/div>\n\n    <!-- Step 4 -->\n    <div id=\"step-4\" class=\"onboarding-step\">\n      <div class=\"feedback-row\">\n<h2><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">¿Fue útil esto?<\/font><\/font><\/h2>\n<div class=\"step-buttons\">\n<button class=\"secondary\" id=\"back-btn-4\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">←<\/font><\/font><\/button><button id=\"helpful-btn\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Útil<\/font><\/font><\/button><button class=\"secondary\" id=\"not-helpful-btn\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">Contactar con soporte técnico<\/font><\/font><\/button>\n<\/div>\n<\/div>\n    <\/div>\n  <\/div>\n\n  <!-- Modal -->\n  <div class=\"modal-overlay\" id=\"video-modal\">\n    <div class=\"modal-content\">\n      <button class=\"modal-close\" id=\"modal-close\"><font dir=\"auto\" style=\"vertical-align: inherit;\"><font dir=\"auto\" style=\"vertical-align: inherit;\">×<\/font><\/font><\/button>\n      <div class=\"overlay-icon\" id=\"overlay-icon\"><\/div>\n      <video id=\"modal-video\" autoplay=\"\" playsinline=\"\"><\/video>\n    <\/div>\n  <\/div>\n\n  <script>\n    const totalSteps = 5,\n          steps = Array.from(document.querySelectorAll('.onboarding-step')),\n          progressBar = document.getElementById('progress-bar'),\n          modal = document.getElementById('video-modal'),\n          modalVideo = document.getElementById('modal-video'),\n          closeBtn = document.getElementById('modal-close'),\n          overlayIcon = document.getElementById('overlay-icon');\n    let currentStep = 0;\n    let overlayTimeout;\n\n    const updateProgress = s => {\n      \/\/ Set width; CSS transition will animate\n      progressBar.style.width = `${s\/(totalSteps-1)*100}%`;\n    };\n    const showStep = s => { steps.forEach((el,i)=>el.classList.toggle('active', i===s)); currentStep=s; updateProgress(s); };\n\n    \/\/ Navigation\n    document.getElementById('continue-btn').addEventListener('click', () => showStep(1));\n    document.getElementById('next-btn-1').addEventListener('click', () => showStep(2));\n    document.getElementById('next-btn-2').addEventListener('click', () => showStep(3));\n    document.getElementById('next-btn-3').addEventListener('click', () => showStep(4));\n    document.getElementById('back-btn-1').addEventListener('click', () => showStep(0));\n    document.getElementById('back-btn-2').addEventListener('click', () => showStep(1));\n    document.getElementById('back-btn-3').addEventListener('click', () => showStep(2));\n    document.getElementById('back-btn-4').addEventListener('click', () => showStep(3));\n\n    \/\/ Tutorial Buttons: open modal and autoplay\n    document.querySelectorAll('.tutorial-btn').forEach(btn => {\n      btn.addEventListener('click', (e) => {\n        const src = e.currentTarget.getAttribute('data-video');\n        modalVideo.src = src;\n        modal.classList.add('active');\n        modalVideo.play();\n      });\n    });\n\n    \/\/ Close Modal\n    closeBtn.addEventListener('click', () => {\n      modal.classList.remove('active');\n      modalVideo.pause();\n    });\n    modal.addEventListener('click', (e) => {\n      if (e.target === modal) {\n        modal.classList.remove('active');\n        modalVideo.pause();\n      }\n    });\n\n    \/\/ Toggle play\/pause and overlay icon\n    modalVideo.addEventListener('click', () => {\n      if (modalVideo.paused) {\n        modalVideo.play();\n        overlayIcon.textContent = '▶︎';\n      } else {\n        modalVideo.pause();\n        overlayIcon.textContent = '❚❚';\n      }\n      overlayIcon.classList.add('show');\n      clearTimeout(overlayTimeout);\n      overlayTimeout = setTimeout(() => overlayIcon.classList.remove('show'), 600);\n    });\n\n    \/\/ Helpful feedback action\n    document.getElementById('helpful-btn').addEventListener('click', () => {\n      const row = document.querySelector('#step-4 .feedback-row');\n      \/\/ Insert new content\n      row.innerHTML = `\n        <h2>Thanks for your feedback!<\/h2>\n        <p>Join <a href=\"https:\/\/www.facebook.com\/groups\/1059547266003676\" target=\"_blank\" style=\"color:#00fea9;\">Nosey People<\/a>—our VIP circle of nose breathers & curious minds. You'll get early drops, exclusive perks, & direct access to the Intake team.<\/p>\n      `;\n      \/\/ Prepare elements for animation\n      const h2 = row.querySelector('h2');\n      const p = row.querySelector('p');\n      h2.style.opacity = '0';\n      h2.style.transform = 'translateY(20px)';\n      p.style.opacity = '0';\n      p.style.transform = 'translateY(20px)';\n      \/\/ Force reflow\n      void row.offsetWidth;\n      \/\/ Animate h2 in\n      setTimeout(() => {\n        h2.style.transition = 'opacity 0.8s ease, transform 0.8s ease';\n        h2.style.opacity = '1';\n        h2.style.transform = 'translateY(0)';\n      }, 200);\n      \/\/ Animate p in\n      setTimeout(() => {\n        p.style.transition = 'opacity 0.8s ease, transform 0.8s ease';\n        p.style.opacity = '1';\n        p.style.transform = 'translateY(0)';\n      }, 400);\n    });\n\n        \/\/ Contact Support feedback action\n    document.getElementById('not-helpful-btn').addEventListener('click', () => {\n      const row = document.querySelector('#step-4 .feedback-row');\n      \/\/ Insert new content\n      row.innerHTML = `\n        <h2>We're sorry you aren't experiencing better breathing.<\/h2>\n        <p>Please <a href=\"mailto:info@intakebreathing.com\" style=\"color:#00fea9;\">email us at info@intakebreathing.com<\/a> and our team will help you out.<\/p>\n      `;\n      \/\/ Prepare elements for animation\n      const h2 = row.querySelector('h2');\n      const p = row.querySelector('p');\n      h2.style.opacity = '0';\n      h2.style.transform = 'translateY(20px)';\n      p.style.opacity = '0';\n      p.style.transform = 'translateY(20px)';\n      \/\/ Force reflow\n      void row.offsetWidth;\n      \/\/ Animate h2 in\n      setTimeout(() => {\n        h2.style.transition = 'opacity 0.8s ease, transform 0.8s ease';\n        h2.style.opacity = '1';\n        h2.style.transform = 'translateY(0)';\n      }, 200);\n      \/\/ Animate p in\n      setTimeout(() => {\n        p.style.transition = 'opacity 0.8s ease, transform 0.8s ease';\n        p.style.opacity = '1';\n        p.style.transform = 'translateY(0)';\n      }, 400);\n    });\n\n    \/\/ Initialize\n    updateProgress(0);\n  <\/script>\n<\/div>\n  <\/div>","padding_top":36,"padding_bottom":36,"remove_spacing":false}}},"order":["main","custom_personalizado_Nizfg8"]}