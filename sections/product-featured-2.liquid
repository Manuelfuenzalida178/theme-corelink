<!-- Featured Products Section - Premium Design -->
<div class="fp-section-root">
  <div class="fp-container">
    <!-- Section Header -->
    <div class="fp-header">
      {% if section.settings.badge_text != blank %}
      <div class="fp-badge">
        <svg class="fp-badge-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
        </svg>
        <span class="fp-badge-text">{{ section.settings.badge_text }}</span>
      </div>
      {% endif %}
      
      {% if section.settings.heading != blank %}
      <h2 class="fp-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% if section.settings.description != blank %}
      <p class="fp-description">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <!-- Products Grid -->
    <div class="fp-grid">
      {% for block in section.blocks %}
        {% if block.settings.product != blank %}
          {% assign product = block.settings.product %}
          {% assign discount_percentage = 0 %}
          
          {% if product.compare_at_price > product.price %}
            {% assign discount = product.compare_at_price | minus: product.price %}
            {% assign discount_percentage = discount | times: 100.0 | divided_by: product.compare_at_price | round %}
          {% endif %}

          <div class="fp-card-group" {{ block.shopify_attributes }}>
            <!-- Product Card -->
            <div class="fp-card">
              <!-- Shine Effect -->
              <div class="fp-shine"></div>
              
              <!-- Product Image -->
              <a href="{{ product.url }}" class="fp-image-link">
                {% if product.featured_image %}
                  <img 
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | default: product.title }}"
                    class="fp-image"
                    loading="lazy"
                  />
                {% else %}
                  <div class="fp-placeholder">
                    <svg class="fp-placeholder-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                {% endif %}
              </a>
              
              <!-- Discount Badge -->
              {% if discount_percentage > 0 %}
              <div class="fp-discount">-{{ discount_percentage }}% OFF</div>
              {% endif %}

              <!-- Quick Add Button -->
              <button 
                type="button"
                class="fp-quick-add"
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
              >
                <svg class="fp-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
                Quick Add
              </button>
            </div>
            
            <!-- Product Info -->
            <div class="fp-info">
              <!-- Rating -->
              {% if product.metafields.reviews.rating.value %}
              <div class="fp-rating">
                <div class="fp-stars">
                  {% assign rating = product.metafields.reviews.rating.value | round %}
                  {% for i in (1..5) %}
                    {% if i <= rating %}
                      <svg class="fp-star-filled" viewBox="0 0 24 24">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                      </svg>
                    {% else %}
                      <svg class="fp-star-empty" viewBox="0 0 24 24">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                      </svg>
                    {% endif %}
                  {% endfor %}
                </div>
                <span class="fp-rating-text">{{ product.metafields.reviews.rating.value }} ({{ product.metafields.reviews.rating_count }})</span>
              </div>
              {% endif %}
              
              <!-- Product Title -->
              <a href="{{ product.url }}" class="fp-title-link">
                <h3 class="fp-title">{{ product.title }}</h3>
              </a>
              
              <!-- Subtitle -->
              {% if block.settings.subtitle != blank %}
              <p class="fp-subtitle">{{ block.settings.subtitle }}</p>
              {% elsif product.metafields.custom.subtitle %}
              <p class="fp-subtitle">{{ product.metafields.custom.subtitle }}</p>
              {% endif %}
              
              <!-- Price -->
              <div class="fp-price">
                <span class="fp-price-current">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                <span class="fp-price-compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
  /* Nuclear reset - override everything from Shopify */
  .fp-section-root,
  .fp-section-root * {
    all: unset !important;
    box-sizing: border-box !important;
  }

  /* Section Root */
  .fp-section-root {
    display: block !important;
    width: 100% !important;
    padding-top: 80px !important;
    padding-bottom: 112px !important;
    background: linear-gradient(180deg, #ffffff 0%, #FFFBFC 50%, #ffffff 100%) !important;
  }

  /* Container */
  .fp-container {
    display: block !important;
    max-width: 1280px !important;
    margin-left: auto !important;
    margin-right: auto !important;
    padding-left: 16px !important;
    padding-right: 16px !important;
  }

  /* Header */
  .fp-header {
    display: block !important;
    text-align: center !important;
    margin-bottom: 64px !important;
  }

  /* Badge */
  .fp-badge {
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    background: linear-gradient(90deg, #FFF5F7 0%, #F8F3FF 100%) !important;
    padding: 10px 20px !important;
    border-radius: 9999px !important;
    margin-bottom: 24px !important;
    border: 1px solid #FFE8F0 !important;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05) !important;
  }

  .fp-badge-icon {
    display: block !important;
    width: 16px !important;
    height: 16px !important;
    color: #E8B4D9 !important;
    flex-shrink: 0 !important;
  }

  .fp-badge-text {
    display: inline !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    letter-spacing: 0.2em !important;
    line-height: 1 !important;
    color: #000000 !important;
    text-transform: uppercase !important;
  }

  /* Heading */
  .fp-heading {
    display: block !important;
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 48px !important;
    font-weight: 400 !important;
    line-height: 1.2 !important;
    color: #000000 !important;
    margin-bottom: 24px !important;
    text-align: center !important;
  }

  /* Description */
  .fp-description {
    display: block !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 20px !important;
    font-weight: 400 !important;
    line-height: 1.5 !important;
    color: #4B5563 !important;
    max-width: 672px !important;
    margin-left: auto !important;
    margin-right: auto !important;
    text-align: center !important;
  }

  /* Grid */
  .fp-grid {
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 24px !important;
  }

  /* Card Group */
  .fp-card-group {
    display: block !important;
    position: relative !important;
  }

  /* Card */
  .fp-card {
    display: block !important;
    position: relative !important;
    background: linear-gradient(135deg, #FFF5F7 0%, #FFF9FC 50%, #F8F3FF 100%) !important;
    border-radius: 32px !important;
    overflow: hidden !important;
    margin-bottom: 20px !important;
    width: 100% !important;
    padding-bottom: 133.33% !important; /* 3:4 aspect ratio */
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05) !important;
    border: 1px solid rgba(255, 255, 255, 0.5) !important;
    transition: box-shadow 0.5s ease !important;
  }

  .fp-card-group:hover .fp-card {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25) !important;
  }

  /* Shine Effect */
  .fp-shine {
    display: block !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    background: linear-gradient(135deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%) !important;
    opacity: 0 !important;
    transform: translateX(-100%) !important;
    transition: all 1s ease !important;
    pointer-events: none !important;
    z-index: 2 !important;
  }

  .fp-card-group:hover .fp-shine {
    opacity: 1 !important;
    transform: translateX(100%) !important;
  }

  /* Image Link */
  .fp-image-link {
    display: block !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    z-index: 1 !important;
    text-decoration: none !important;
  }

  /* Image */
  .fp-image {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    transition: transform 0.7s ease !important;
  }

  .fp-card-group:hover .fp-image {
    transform: scale(1.05) !important;
  }

  /* Placeholder */
  .fp-placeholder {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    height: 100% !important;
    background: #E5E7EB !important;
  }

  .fp-placeholder-icon {
    display: block !important;
    width: 64px !important;
    height: 64px !important;
    color: #9CA3AF !important;
  }

  /* Discount Badge */
  .fp-discount {
    display: block !important;
    position: absolute !important;
    top: 20px !important;
    left: 20px !important;
    background: linear-gradient(90deg, #B8A4E8 0%, #D4A5D7 100%) !important;
    color: #ffffff !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    line-height: 1 !important;
    padding: 8px 16px !important;
    border-radius: 9999px !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1) !important;
    backdrop-filter: blur(4px) !important;
    z-index: 3 !important;
  }

  /* Quick Add Button */
  .fp-quick-add {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    position: absolute !important;
    bottom: 20px !important;
    left: 20px !important;
    right: 20px !important;
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(4px) !important;
    color: #111827 !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    line-height: 1 !important;
    padding: 14px 20px !important;
    border-radius: 9999px !important;
    opacity: 0 !important;
    transform: translateY(8px) !important;
    transition: all 0.3s ease !important;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25) !important;
    border: none !important;
    cursor: pointer !important;
    z-index: 3 !important;
  }

  .fp-card-group:hover .fp-quick-add {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  .fp-quick-add:hover {
    background: #111827 !important;
    color: #ffffff !important;
  }

  .fp-btn-icon {
    display: block !important;
    width: 16px !important;
    height: 16px !important;
    flex-shrink: 0 !important;
  }

  /* Product Info */
  .fp-info {
    display: block !important;
    padding-left: 8px !important;
    padding-right: 8px !important;
  }

  /* Rating */
  .fp-rating {
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    margin-bottom: 12px !important;
  }

  .fp-stars {
    display: flex !important;
    align-items: center !important;
    gap: 2px !important;
  }

  .fp-star-filled,
  .fp-star-empty {
    display: block !important;
    width: 16px !important;
    height: 16px !important;
    flex-shrink: 0 !important;
  }

  .fp-star-filled {
    fill: #FFB800 !important;
    color: #FFB800 !important;
  }

  .fp-star-empty {
    fill: #E5E7EB !important;
    color: #E5E7EB !important;
  }

  .fp-rating-text {
    display: inline !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 12px !important;
    font-weight: 500 !important;
    line-height: 1 !important;
    color: #4B5563 !important;
    margin-left: 4px !important;
  }

  /* Title Link */
  .fp-title-link {
    display: block !important;
    text-decoration: none !important;
    color: inherit !important;
  }

  /* Title */
  .fp-title {
    display: block !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 18px !important;
    font-weight: 600 !important;
    line-height: 1.4 !important;
    color: #000000 !important;
    margin-bottom: 8px !important;
    transition: color 0.3s ease !important;
  }

  .fp-card-group:hover .fp-title {
    color: #B8A4E8 !important;
  }

  /* Subtitle */
  .fp-subtitle {
    display: block !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 14px !important;
    font-weight: 400 !important;
    line-height: 1.6 !important;
    color: #6B7280 !important;
    margin-bottom: 16px !important;
  }

  /* Price */
  .fp-price {
    display: flex !important;
    align-items: baseline !important;
    gap: 12px !important;
  }

  .fp-price-current {
    display: inline !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 24px !important;
    font-weight: 700 !important;
    line-height: 1 !important;
    color: #000000 !important;
  }

  .fp-price-compare {
    display: inline !important;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    line-height: 1 !important;
    color: #9CA3AF !important;
    text-decoration: line-through !important;
  }

  /* Responsive */
  @media (min-width: 640px) {
    .fp-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (min-width: 1024px) {
    .fp-section-root {
      padding-top: 112px !important;
      padding-bottom: 112px !important;
    }

    .fp-container {
      padding-left: 32px !important;
      padding-right: 32px !important;
    }

    .fp-heading {
      font-size: 60px !important;
    }

    .fp-grid {
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 32px !important;
    }
  }

  /* Loading spinner */
  @keyframes fp-spin {
    to { transform: rotate(360deg) !important; }
  }

  .fp-spin {
    animation: fp-spin 1s linear infinite !important;
  }
</style>

<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var buttons = document.querySelectorAll('.fp-quick-add');
    
    buttons.forEach(function(btn) {
      btn.addEventListener('click', async function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        var vid = this.dataset.variantId;
        var origHTML = this.innerHTML;
        
        this.innerHTML = '<svg class="fp-btn-icon fp-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity="0.25"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" opacity="0.75"></path></svg> Adding...';
        this.disabled = true;
        
        try {
          var res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: vid, quantity: 1 })
          });
          
          if (res.ok) {
            this.innerHTML = '<svg class="fp-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Added!';
            this.style.setProperty('background', '#10B981', 'important');
            this.style.setProperty('color', '#ffffff', 'important');
            
            try {
              var cart = await fetch('/cart.js').then(function(r) { return r.json(); });
              document.querySelectorAll('[data-cart-count]').forEach(function(el) {
                el.textContent = cart.item_count;
              });
              if (typeof window.openCartDrawer === 'function') window.openCartDrawer();
              document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
            } catch(e) {}
            
            setTimeout(function() {
              this.innerHTML = origHTML;
              this.style.removeProperty('background');
              this.style.removeProperty('color');
              this.disabled = false;
            }.bind(this), 2000);
          } else {
            throw new Error('Failed');
          }
        } catch(err) {
          this.innerHTML = '<svg class="fp-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg> Error';
          this.style.setProperty('background', '#EF4444', 'important');
          this.style.setProperty('color', '#ffffff', 'important');
          
          setTimeout(function() {
            this.innerHTML = origHTML;
            this.style.removeProperty('background');
            this.style.removeProperty('color');
            this.disabled = false;
          }.bind(this), 2000);
        }
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "section-fp",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "BESTSELLERS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Our Favorites"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover the tools and treatments our customers can't live without"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Custom Subtitle (Optional)",
          "info": "Leave blank to use product metafield"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}
