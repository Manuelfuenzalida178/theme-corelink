{% comment %}
  Section: Preguntas Frecuentes
  Descripción: Sección compacta de preguntas frecuentes con diseño de acordeón
{% endcomment %}

<style>
  #faq-section-{{ section.id }} * {
    box-sizing: border-box;
  }
  
  #faq-section-{{ section.id }} .faq-container {
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }
  
  #faq-section-{{ section.id }} .faq-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }
  
  #faq-section-{{ section.id }} .faq-header {
    text-align: center;
    margin-bottom: 30px;
  }
  
  #faq-section-{{ section.id }} .faq-title {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #000000;
    margin: 0 0 8px 0;
    letter-spacing: -0.5px;
    line-height: 1.2;
  }
  
  #faq-section-{{ section.id }} .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  
  #faq-section-{{ section.id }} .faq-item {
    background: #ffffff;
    border-radius: 10px;
    border: 1px solid #e5e5e5;
    overflow: hidden;
    transition: all 0.2s ease;
  }
  
  #faq-section-{{ section.id }} .faq-question {
    width: 100%;
    padding: 16px 20px;
    background: transparent;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background 0.2s ease;
  }
  
  #faq-section-{{ section.id }} .faq-question:hover {
    background: #fafafa;
  }
  
  #faq-section-{{ section.id }} .faq-question-text {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #000000;
    line-height: 1.4;
    margin: 0;
    flex: 1;
  }
  
  #faq-section-{{ section.id }} .faq-icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  
  #faq-section-{{ section.id }} .faq-item.active .faq-icon {
    transform: rotate(180deg);
  }
  
  #faq-section-{{ section.id }} .faq-icon svg {
    width: 12px;
    height: 12px;
  }
  
  #faq-section-{{ section.id }} .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }
  
  #faq-section-{{ section.id }} .faq-item.active .faq-answer {
    max-height: 500px;
    padding: 0 20px 16px 20px;
    border-top: 1px solid #f0f0f0;
    padding-top: 12px;
  }
  
  #faq-section-{{ section.id }} .faq-answer-content {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
    margin: 0;
  }
  
  @media (max-width: 767px) {
    #faq-section-{{ section.id }} .faq-title {
      font-size: 24px;
    }
    
    #faq-section-{{ section.id }} .faq-header {
      margin-bottom: 24px;
    }
    
    #faq-section-{{ section.id }} .faq-list {
      gap: 8px;
    }
    
    #faq-section-{{ section.id }} .faq-question {
      padding: 14px 16px;
      gap: 12px;
    }
    
    #faq-section-{{ section.id }} .faq-question-text {
      font-size: 14px;
    }
    
    #faq-section-{{ section.id }} .faq-icon {
      width: 22px;
      height: 22px;
    }
    
    #faq-section-{{ section.id }} .faq-icon svg {
      width: 10px;
      height: 10px;
    }
    
    #faq-section-{{ section.id }} .faq-item.active .faq-answer {
      padding: 0 16px 14px 16px;
      padding-top: 10px;
    }
    
    #faq-section-{{ section.id }} .faq-answer-content {
      font-size: 13px;
    }
  }
</style>

<div id="faq-section-{{ section.id }}">
  <div class="faq-container">
    <div class="faq-inner">
      
      <!-- Header -->
      {% if section.settings.show_title %}
        <div class="faq-header">
          <h2 class="faq-title">{{ section.settings.title }}</h2>
        </div>
      {% endif %}

      <!-- FAQ List -->
      <div class="faq-list">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <div class="faq-item {% if forloop.first and section.settings.first_open %}active{% endif %}" data-faq-item {{ block.shopify_attributes }}>
              <button class="faq-question" type="button" data-faq-question>
                <h3 class="faq-question-text">{{ block.settings.question }}</h3>
                <div class="faq-icon">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 9L12 16L5 9" stroke="#666666" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </button>
              <div class="faq-answer">
                <div class="faq-answer-content">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

    </div>
  </div>
</div>

<script>
(function() {
  const faqItems = document.querySelectorAll('#faq-section-{{ section.id }} [data-faq-item]');
  
  faqItems.forEach(item => {
    const question = item.querySelector('[data-faq-question]');
    
    question.addEventListener('click', () => {
      const isActive = item.classList.contains('active');
      
      // Close all items (accordion behavior - only one open at a time)
      faqItems.forEach(otherItem => {
        if (otherItem !== item) {
          otherItem.classList.remove('active');
        }
      });
      
      // Toggle current item
      item.classList.toggle('active');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Preguntas Frecuentes",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Espacio superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Espacio inferior",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Mostrar título",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Preguntas Frecuentes"
    },
    {
      "type": "header",
      "content": "Comportamiento"
    },
    {
      "type": "checkbox",
      "id": "first_open",
      "label": "Abrir primera pregunta por defecto",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Cuál es tu pregunta?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Escribe aquí la respuesta a la pregunta frecuente.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Preguntas Frecuentes",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Cuánto tarda el envío?",
            "answer": "<p>Los envíos estándar tardan entre 3-5 días hábiles. Ofrecemos envío express de 1-2 días hábiles por un costo adicional.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Cuál es la política de devoluciones?",
            "answer": "<p>Aceptamos devoluciones dentro de los 30 días posteriores a la compra. El producto debe estar sin usar y en su empaque original.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Los productos tienen garantía?",
            "answer": "<p>Sí, todos nuestros productos cuentan con garantía de satisfacción de 30 días. Si no estás completamente satisfecho, te devolvemos tu dinero.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Cómo puedo rastrear mi pedido?",
            "answer": "<p>Una vez que tu pedido sea enviado, recibirás un correo electrónico con el número de seguimiento y un enlace para rastrear tu paquete en tiempo real.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Puedo modificar o cancelar mi pedido?",
            "answer": "<p>Puedes modificar o cancelar tu pedido dentro de las primeras 2 horas después de realizar la compra. Después de ese tiempo, el pedido ya estará en proceso de preparación.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
