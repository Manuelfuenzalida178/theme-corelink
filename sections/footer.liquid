<!-- Corelink Footer v2 - Professional Design -->
<style>
  /* ===== BASE RESET ===== */
  .corelink-footer-wrapper * {
    box-sizing: border-box !important;
  }

  .corelink-footer-wrapper {
    all: initial;
    display: block;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important;
    line-height: 1.5 !important;
    -webkit-font-smoothing: antialiased !important;
    -moz-osx-font-smoothing: grayscale !important;
  }

  .corelink-footer-wrapper footer {
    background-color: {{ section.settings.footer_bg_color }} !important;
    width: 100% !important;
    display: block !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* ===== NEWSLETTER ===== */
  .corelink-newsletter-section {
    background: linear-gradient(135deg, {{ section.settings.newsletter_bg_color_1 }} 0%, {{ section.settings.newsletter_bg_color_2 }} 100%) !important;
    width: 100% !important;
    position: relative !important;
    overflow: hidden !important;
  }

  .corelink-newsletter-section::before {
    content: '' !important;
    position: absolute !important;
    top: -60% !important;
    right: -5% !important;
    width: 420px !important;
    height: 420px !important;
    background: rgba(255,255,255,0.06) !important;
    border-radius: 50% !important;
    pointer-events: none !important;
  }

  .corelink-newsletter-section::after {
    content: '' !important;
    position: absolute !important;
    bottom: -60% !important;
    left: -5% !important;
    width: 300px !important;
    height: 300px !important;
    background: rgba(255,255,255,0.04) !important;
    border-radius: 50% !important;
    pointer-events: none !important;
  }

  .corelink-newsletter-inner {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 2.75rem 1.5rem !important;
    position: relative !important;
    z-index: 1 !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 1.75rem !important;
    align-items: flex-start !important;
  }

  @media (min-width: 768px) {
    .corelink-newsletter-inner {
      flex-direction: row !important;
      justify-content: space-between !important;
      align-items: center !important;
      gap: 3rem !important;
    }
  }

  .corelink-newsletter-text {
    flex: 1 !important;
    min-width: 0 !important;
  }

  .corelink-newsletter-eyebrow {
    display: inline-block !important;
    font-size: 0.6875rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    color: rgba(255,255,255,0.7) !important;
    margin-bottom: 0.5rem !important;
  }

  .corelink-newsletter-title {
    font-size: 1.5rem !important;
    font-weight: 800 !important;
    color: #ffffff !important;
    margin: 0 0 0.625rem 0 !important;
    line-height: 1.25 !important;
  }

  @media (min-width: 768px) {
    .corelink-newsletter-title {
      font-size: 1.75rem !important;
    }
  }

  .corelink-newsletter-desc {
    color: rgba(255,255,255,0.82) !important;
    font-size: 0.9375rem !important;
    margin: 0 !important;
    line-height: 1.6 !important;
  }

  .corelink-newsletter-form-wrapper {
    flex: 0 0 auto !important;
    width: 100% !important;
  }

  @media (min-width: 768px) {
    .corelink-newsletter-form-wrapper {
      width: 420px !important;
    }
  }

  .corelink-newsletter-form {
    display: flex !important;
    flex-direction: column !important;
    gap: 0.625rem !important;
  }

  @media (min-width: 480px) {
    .corelink-newsletter-form {
      flex-direction: row !important;
    }
  }

  .corelink-newsletter-input-wrapper {
    flex: 1 !important;
    display: flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
    background-color: rgba(255,255,255,0.15) !important;
    border: 1.5px solid rgba(255,255,255,0.28) !important;
    border-radius: 0.625rem !important;
    padding: 0.75rem 1rem !important;
    transition: background-color 0.2s ease, border-color 0.2s ease !important;
    min-width: 0 !important;
  }

  .corelink-newsletter-input-wrapper:focus-within {
    background-color: rgba(255,255,255,0.22) !important;
    border-color: rgba(255,255,255,0.55) !important;
  }

  .corelink-newsletter-input-icon {
    width: 1rem !important;
    height: 1rem !important;
    color: rgba(255,255,255,0.65) !important;
    flex-shrink: 0 !important;
  }

  .corelink-newsletter-input {
    flex: 1 !important;
    font-size: 0.875rem !important;
    color: #ffffff !important;
    background-color: transparent !important;
    border: none !important;
    outline: none !important;
    min-width: 0 !important;
  }

  .corelink-newsletter-input::placeholder {
    color: rgba(255,255,255,0.55) !important;
  }

  .corelink-newsletter-submit {
    padding: 0.75rem 1.625rem !important;
    background-color: {{ section.settings.button_bg_color }} !important;
    color: {{ section.settings.button_text_color }} !important;
    font-size: 0.875rem !important;
    font-weight: 700 !important;
    border-radius: 0.625rem !important;
    border: none !important;
    cursor: pointer !important;
    white-space: nowrap !important;
    transition: opacity 0.2s ease, transform 0.15s ease !important;
    letter-spacing: 0.01em !important;
  }

  .corelink-newsletter-submit:hover {
    opacity: 0.85 !important;
    transform: translateY(-1px) !important;
  }

  .corelink-newsletter-disclaimer {
    color: rgba(255,255,255,0.55) !important;
    font-size: 0.75rem !important;
    margin-top: 0.625rem !important;
    line-height: 1.5 !important;
  }

  .corelink-newsletter-disclaimer a {
    text-decoration: underline !important;
    color: rgba(255,255,255,0.7) !important;
  }

  .corelink-newsletter-disclaimer a:hover {
    color: #ffffff !important;
  }

  /* ===== MAIN FOOTER AREA ===== */
  .corelink-footer-main-bg {
    background-color: {{ section.settings.footer_bg_color }} !important;
    width: 100% !important;
  }

  .corelink-footer-main {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 3.5rem 1.5rem 2.5rem !important;
  }

  .corelink-footer-grid {
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 2rem !important;
  }

  @media (min-width: 640px) {
    .corelink-footer-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 2rem 2.5rem !important;
    }
  }

  @media (min-width: 1024px) {
    .corelink-footer-grid {
      grid-template-columns: 2.4fr 1fr 1fr 1fr 1.5fr !important;
      gap: 2.5rem !important;
      align-items: start !important;
    }
  }

  /* ===== BRAND COLUMN ===== */
  .corelink-footer-col-1 {
    grid-column: span 1 !important;
  }

  @media (min-width: 640px) {
    .corelink-footer-col-1 {
      grid-column: span 2 !important;
    }
  }

  @media (min-width: 1024px) {
    .corelink-footer-col-1 {
      grid-column: span 1 !important;
    }
  }

  .corelink-footer-logo {
    height: 2.25rem !important;
    margin-bottom: 1.25rem !important;
    display: block !important;
    max-width: 160px !important;
    object-fit: contain !important;
    object-position: left center !important;
  }

  .corelink-footer-brand-text {
    color: #6b7280 !important;
    font-size: 0.875rem !important;
    line-height: 1.75 !important;
    margin-bottom: 1.75rem !important;
    max-width: 280px !important;
  }

  .corelink-footer-social-label {
    font-size: 0.6875rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    color: #9ca3af !important;
    margin-bottom: 0.75rem !important;
  }

  .corelink-footer-social-links {
    display: flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
    flex-wrap: wrap !important;
  }

  .corelink-footer-social-link {
    width: 2.25rem !important;
    height: 2.25rem !important;
    border: 1.5px solid #e5e7eb !important;
    border-radius: 0.5rem !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.15s ease !important;
    text-decoration: none !important;
    background: transparent !important;
  }

  .corelink-footer-social-link:hover {
    background-color: {{ section.settings.accent_color }} !important;
    border-color: {{ section.settings.accent_color }} !important;
    transform: translateY(-2px) !important;
  }

  .corelink-footer-social-link svg {
    width: 1rem !important;
    height: 1rem !important;
    color: #6b7280 !important;
    transition: color 0.2s ease !important;
    display: block !important;
  }

  .corelink-footer-social-link:hover svg {
    color: #ffffff !important;
  }

  /* ===== MENU COLUMNS ===== */
  .corelink-footer-col-2,
  .corelink-footer-col-3,
  .corelink-footer-col-4,
  .corelink-footer-col-5 {
    grid-column: span 1 !important;
  }

  .corelink-footer-accordion-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100% !important;
    text-align: left !important;
    padding: 0 !important;
    background: none !important;
    border: none !important;
    cursor: pointer !important;
    margin-bottom: 1.125rem !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-accordion-btn {
      pointer-events: none !important;
      cursor: default !important;
    }
  }

  .corelink-footer-section-title {
    font-size: 0.6875rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    color: #111827 !important;
    margin: 0 !important;
  }

  .corelink-footer-chevron {
    width: 1.125rem !important;
    height: 1.125rem !important;
    color: #9ca3af !important;
    transition: transform 0.25s ease !important;
    flex-shrink: 0 !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-chevron {
      display: none !important;
    }
  }

  .corelink-footer-chevron.active {
    transform: rotate(180deg) !important;
  }

  .corelink-footer-links {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    transition: max-height 0.35s ease !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-links {
      max-height: none !important;
    }
  }

  .corelink-footer-links.active {
    max-height: 32rem !important;
  }

  .corelink-footer-links li {
    margin: 0 0 0.5rem 0 !important;
    padding: 0 !important;
  }

  .corelink-footer-links li:last-child {
    margin-bottom: 0 !important;
  }

  .corelink-footer-links a {
    color: #6b7280 !important;
    font-size: 0.875rem !important;
    text-decoration: none !important;
    transition: color 0.2s ease, padding-left 0.2s ease !important;
    display: inline-block !important;
    position: relative !important;
    padding-left: 0 !important;
  }

  .corelink-footer-links a:hover {
    color: {{ section.settings.accent_color }} !important;
    padding-left: 0.75rem !important;
  }

  .corelink-footer-links a::before {
    content: '' !important;
    position: absolute !important;
    left: 0 !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    width: 0 !important;
    height: 1.5px !important;
    background-color: {{ section.settings.accent_color }} !important;
    transition: width 0.2s ease !important;
    border-radius: 9999px !important;
  }

  .corelink-footer-links a:hover::before {
    width: 0.5rem !important;
  }

  /* ===== CONTACT ITEMS ===== */
  .corelink-footer-contact-list {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    transition: max-height 0.35s ease !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-contact-list {
      max-height: none !important;
    }
  }

  .corelink-footer-contact-list.active {
    max-height: 32rem !important;
  }

  .corelink-footer-contact-item {
    display: flex !important;
    align-items: flex-start !important;
    gap: 0.625rem !important;
    color: #6b7280 !important;
    font-size: 0.875rem !important;
    margin: 0 0 0.875rem 0 !important;
    padding: 0 !important;
    line-height: 1.55 !important;
  }

  .corelink-footer-contact-item:last-child {
    margin-bottom: 0 !important;
  }

  .corelink-footer-contact-icon {
    width: 1rem !important;
    height: 1rem !important;
    color: {{ section.settings.accent_color }} !important;
    flex-shrink: 0 !important;
    margin-top: 0.1875rem !important;
  }

  .corelink-footer-contact-link {
    color: inherit !important;
    text-decoration: none !important;
    transition: color 0.2s ease !important;
  }

  .corelink-footer-contact-link:hover {
    color: {{ section.settings.accent_color }} !important;
  }

  /* ===== INNER DIVIDER ===== */
  .corelink-footer-sep {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 0 1.5rem !important;
  }

  .corelink-footer-sep hr {
    border: none !important;
    border-top: 1px solid #f3f4f6 !important;
    margin: 0 !important;
  }

  /* ===== PAYMENT METHODS ===== */
  .corelink-footer-payments-bg {
    background-color: {{ section.settings.footer_bg_color }} !important;
  }

  .corelink-footer-payments {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 1.25rem 1.5rem !important;
    display: flex !important;
    align-items: center !important;
    flex-wrap: wrap !important;
    gap: 0.75rem !important;
  }

  .corelink-footer-payments-label {
    font-size: 0.75rem !important;
    font-weight: 600 !important;
    color: #9ca3af !important;
    letter-spacing: 0.05em !important;
    white-space: nowrap !important;
  }

  .corelink-footer-payment-icons {
    display: flex !important;
    align-items: center !important;
    gap: 0.375rem !important;
    flex-wrap: wrap !important;
  }

  .corelink-footer-payment-icons svg {
    height: 1.625rem !important;
    width: auto !important;
    display: block !important;
    border-radius: 0.25rem !important;
    border: 1px solid #e5e7eb !important;
  }

  /* ===== BOTTOM BAR ===== */
  .corelink-footer-bottom {
    background-color: #f9fafb !important;
    border-top: 1px solid #f0f0f0 !important;
  }

  .corelink-footer-bottom-content {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 1.125rem 1.5rem !important;
  }

  .corelink-footer-bottom-grid {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 0.625rem !important;
    text-align: center !important;
  }

  @media (min-width: 768px) {
    .corelink-footer-bottom-grid {
      flex-direction: row !important;
      text-align: left !important;
    }
  }

  .corelink-footer-copyright {
    color: #9ca3af !important;
    font-size: 0.8125rem !important;
    margin: 0 !important;
  }

  .corelink-footer-bottom-links {
    display: flex !important;
    align-items: center !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 0.125rem 1.25rem !important;
    font-size: 0.8125rem !important;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  @media (min-width: 768px) {
    .corelink-footer-bottom-links {
      justify-content: flex-end !important;
    }
  }

  .corelink-footer-bottom-links a {
    color: #9ca3af !important;
    text-decoration: none !important;
    transition: color 0.2s ease !important;
  }

  .corelink-footer-bottom-links a:hover {
    color: {{ section.settings.accent_color }} !important;
  }
</style>

<div class="corelink-footer-wrapper">
  <footer>

    <!-- ── Newsletter ── -->
    {% if section.settings.show_newsletter %}
    <div class="corelink-newsletter-section">
      <div class="corelink-newsletter-inner">
        <div class="corelink-newsletter-text">
          <span class="corelink-newsletter-eyebrow">Newsletter</span>
          <h2 class="corelink-newsletter-title">{{ section.settings.newsletter_title }}</h2>
          <p class="corelink-newsletter-desc">{{ section.settings.newsletter_description }}</p>
        </div>

        <div class="corelink-newsletter-form-wrapper">
          <form class="corelink-newsletter-form" action="/contact#newsletter" method="post" accept-charset="UTF-8">
            <input type="hidden" name="form_type" value="customer">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="contact[tags]" value="newsletter">

            <div class="corelink-newsletter-input-wrapper">
              <svg class="corelink-newsletter-input-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              <input
                type="email"
                name="contact[email]"
                placeholder="{{ section.settings.newsletter_placeholder }}"
                class="corelink-newsletter-input"
                required
              />
            </div>
            <button type="submit" class="corelink-newsletter-submit">
              {{ section.settings.newsletter_button_text }}
            </button>
          </form>

          <p class="corelink-newsletter-disclaimer">
            {{ section.settings.newsletter_disclaimer }}
            {% if section.settings.privacy_link != blank %}
              <a href="{{ section.settings.privacy_link }}">{{ section.settings.privacy_link_text }}</a>
            {% endif %}
          </p>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- ── Main Footer Columns ── -->
    <div class="corelink-footer-main-bg">
      <div class="corelink-footer-main">
        <div class="corelink-footer-grid">

          <!-- Col 1 · Brand -->
          <div class="corelink-footer-col-1">
            {% if section.settings.logo != blank %}
              <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name }}" class="corelink-footer-logo">
            {% else %}
              <img src="https://cdn.shopify.com/s/files/1/0745/7505/2971/files/Diseno_sin_titulo_9.svg?v=1767416974" alt="{{ shop.name }}" class="corelink-footer-logo">
            {% endif %}

            <p class="corelink-footer-brand-text">{{ section.settings.brand_description }}</p>

            {% if section.settings.show_social %}
            <div>
              <p class="corelink-footer-social-label">{{ section.settings.social_title }}</p>
              <div class="corelink-footer-social-links">
                {% if section.settings.facebook_url != blank %}
                <a href="{{ section.settings.facebook_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener" aria-label="Facebook">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.instagram_url != blank %}
                <a href="{{ section.settings.instagram_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener" aria-label="Instagram">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.tiktok_url != blank %}
                <a href="{{ section.settings.tiktok_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener" aria-label="TikTok">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.15 8.15 0 0 0 4.77 1.52V6.76a4.85 4.85 0 0 1-1-.07z"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.whatsapp_url != blank %}
                <a href="{{ section.settings.whatsapp_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.twitter_url != blank %}
                <a href="{{ section.settings.twitter_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener" aria-label="Twitter / X">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.youtube_url != blank %}
                <a href="{{ section.settings.youtube_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener" aria-label="YouTube">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/>
                    <path d="m10 15 5-3-5-3z"/>
                  </svg>
                </a>
                {% endif %}
              </div>
            </div>
            {% endif %}
          </div>

          <!-- Col 2 · Menu 1 -->
          <div class="corelink-footer-col-2">
            <button class="corelink-footer-accordion-btn" onclick="corelinkToggle(this, 'menu1')" type="button">
              <h3 class="corelink-footer-section-title">{{ section.settings.menu1_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-links" id="corelink-menu1">
              {% for link in linklists[section.settings.menu1].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <!-- Col 3 · Menu 2 -->
          <div class="corelink-footer-col-3">
            <button class="corelink-footer-accordion-btn" onclick="corelinkToggle(this, 'menu2')" type="button">
              <h3 class="corelink-footer-section-title">{{ section.settings.menu2_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-links" id="corelink-menu2">
              {% for link in linklists[section.settings.menu2].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <!-- Col 4 · Menu 3 -->
          <div class="corelink-footer-col-4">
            <button class="corelink-footer-accordion-btn" onclick="corelinkToggle(this, 'menu3')" type="button">
              <h3 class="corelink-footer-section-title">{{ section.settings.menu3_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-links" id="corelink-menu3">
              {% for link in linklists[section.settings.menu3].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <!-- Col 5 · Contacto -->
          <div class="corelink-footer-col-5">
            <button class="corelink-footer-accordion-btn" onclick="corelinkToggle(this, 'contact')" type="button">
              <h3 class="corelink-footer-section-title">{{ section.settings.contact_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-contact-list" id="corelink-contact">
              {% if section.settings.phone != blank %}
              <li class="corelink-footer-contact-item">
                <svg class="corelink-footer-contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="corelink-footer-contact-link">{{ section.settings.phone }}</a>
              </li>
              {% endif %}
              {% if section.settings.email != blank %}
              <li class="corelink-footer-contact-item">
                <svg class="corelink-footer-contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                <a href="mailto:{{ section.settings.email }}" class="corelink-footer-contact-link">{{ section.settings.email }}</a>
              </li>
              {% endif %}
              {% if section.settings.address != blank %}
              <li class="corelink-footer-contact-item">
                <svg class="corelink-footer-contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span>{{ section.settings.address }}</span>
              </li>
              {% endif %}
              {% if section.settings.store_hours != blank %}
              <li class="corelink-footer-contact-item">
                <svg class="corelink-footer-contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                <span>{{ section.settings.store_hours }}</span>
              </li>
              {% endif %}
            </ul>
          </div>

        </div>
      </div>
    </div>

    <!-- ── Separador ── -->
    <div class="corelink-footer-sep">
      <hr>
    </div>

    <!-- ── Métodos de Pago ── -->
    {% if section.settings.show_payment_icons %}
    <div class="corelink-footer-payments-bg">
      <div class="corelink-footer-payments">
        <span class="corelink-footer-payments-label">{{ section.settings.payment_label }}</span>
        <div class="corelink-footer-payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="corelink-footer-sep">
      <hr>
    </div>
    {% endif %}

    <!-- ── Bottom Bar ── -->
    <div class="corelink-footer-bottom">
      <div class="corelink-footer-bottom-content">
        <div class="corelink-footer-bottom-grid">
          <p class="corelink-footer-copyright">{{ section.settings.copyright_text }}</p>
          <ul class="corelink-footer-bottom-links">
            {% for link in linklists[section.settings.bottom_menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>

  </footer>
</div>

<script>
  function corelinkToggle(btn, id) {
    if (window.innerWidth >= 1024) return;
    var chevron = btn.querySelector('.corelink-footer-chevron');
    var panel = document.getElementById('corelink-' + id);
    if (!panel) return;
    var isOpen = panel.classList.contains('active');
    chevron.classList.toggle('active', !isOpen);
    panel.classList.toggle('active', !isOpen);
  }
</script>

