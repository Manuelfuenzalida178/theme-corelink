<!-- Corelink Footer - Protegido contra estilos de Shopify -->
<style>
  /* Reset y protección contra estilos de Shopify */
  .corelink-footer-wrapper * {
    box-sizing: border-box !important;
  }

  .corelink-footer-wrapper {
    all: initial;
    display: block;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important;
    line-height: 1.5 !important;
    -webkit-font-smoothing: antialiased !important;
    -moz-osx-font-smoothing: grayscale !important;
  }

  .corelink-footer-wrapper footer {
    background-color: #ffffff !important;
    width: 100% !important;
    display: block !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Newsletter Section */
  .corelink-newsletter-section {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 3rem 1.5rem 2rem 1.5rem !important;
  }

  .corelink-newsletter-box {
    background: linear-gradient(to right, {{ section.settings.newsletter_bg_color_1 }}, {{ section.settings.newsletter_bg_color_2 }}) !important;
    border-radius: 1rem !important;
    padding: 1.5rem !important;
    position: relative !important;
    overflow: hidden !important;
  }

  @media (min-width: 768px) {
    .corelink-newsletter-box {
      padding: 2rem !important;
      max-width: 800px !important;
      margin: 0 auto !important;
    }
  }

  .corelink-newsletter-deco1 {
    position: absolute !important;
    top: 1rem !important;
    right: 1rem !important;
    width: 4rem !important;
    height: 4rem !important;
    background-color: rgba(255, 255, 255, 0.1) !important;
    border-radius: 9999px !important;
    filter: blur(2rem) !important;
  }

  .corelink-newsletter-deco2 {
    position: absolute !important;
    bottom: 1rem !important;
    left: 1rem !important;
    width: 6rem !important;
    height: 6rem !important;
    background-color: rgba(255, 255, 255, 0.1) !important;
    border-radius: 9999px !important;
    filter: blur(3rem) !important;
  }

  .corelink-newsletter-grid {
    position: relative !important;
    z-index: 10 !important;
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 1.5rem !important;
    align-items: center !important;
  }

  @media (min-width: 768px) {
    .corelink-newsletter-grid {
      grid-template-columns: 1fr !important;
      justify-items: center !important;
    }
  }

  .corelink-newsletter-icon {
    display: none !important;
  }

  .corelink-newsletter-content {
    color: #ffffff !important;
  }

  @media (min-width: 768px) {
    .corelink-newsletter-content {
      text-align: center !important;
      max-width: 600px !important;
    }
  }

  .corelink-newsletter-title {
    font-size: 1.25rem !important;
    margin-bottom: 0.5rem !important;
    font-weight: 700 !important;
    color: #ffffff !important;
  }

  @media (min-width: 768px) {
    .corelink-newsletter-title {
      font-size: 1.5rem !important;
    }
  }

  .corelink-newsletter-desc {
    color: rgba(255, 255, 255, 0.9) !important;
    margin-bottom: 1rem !important;
    font-size: 0.875rem !important;
  }

  .corelink-newsletter-form {
    display: flex !important;
    flex-direction: column !important;
    gap: 0.5rem !important;
    margin-bottom: 0.75rem !important;
  }

  @media (min-width: 640px) {
    .corelink-newsletter-form {
      flex-direction: row !important;
      justify-content: center !important;
    }
  }

  .corelink-newsletter-input-wrapper {
    flex: 1 !important;
    display: flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
    background-color: #ffffff !important;
    border-radius: 0.5rem !important;
    padding: 0.25rem 1rem !important;
    border: 1px solid #e5e7eb !important;
    transition: all 0.3s !important;
  }

  .corelink-newsletter-input-wrapper:focus-within {
    border-color: #d1d5db !important;
  }

  .corelink-newsletter-input-icon {
    width: 1rem !important;
    height: 1rem !important;
    color: #9ca3af !important;
    flex-shrink: 0 !important;
  }

  .corelink-newsletter-input {
    flex: 1 !important;
    font-size: 0.875rem !important;
    color: #111827 !important;
    background-color: transparent !important;
    border: none !important;
    outline: none !important;
  }

  .corelink-newsletter-input::placeholder {
    color: #6b7280 !important;
  }

  .corelink-newsletter-submit {
    padding: 0.25rem 2rem !important;
    background-color: {{ section.settings.button_bg_color }} !important;
    color: {{ section.settings.button_text_color }} !important;
    font-size: 0.875rem !important;
    border-radius: 0.5rem !important;
    transition: all 0.3s !important;
    font-weight: 600 !important;
    border: none !important;
    cursor: pointer !important;
  }

  .corelink-newsletter-submit:hover {
    background-color: #1f2937 !important;
  }

  .corelink-newsletter-disclaimer {
    color: rgba(255, 255, 255, 0.7) !important;
    font-size: 0.75rem !important;
  }

  .corelink-newsletter-disclaimer a {
    text-decoration: underline !important;
    color: rgba(255, 255, 255, 0.7) !important;
  }

  .corelink-newsletter-disclaimer a:hover {
    color: #ffffff !important;
  }

  /* Main Footer Content */
  .corelink-footer-main-bg {
    background-color: {{ section.settings.footer_bg_color }} !important;
    width: 100% !important;
  }

  .corelink-footer-main {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 3rem 1.5rem !important;
  }

  .corelink-footer-grid {
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 1rem !important;
  }

  @media (min-width: 768px) {
    .corelink-footer-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 2rem !important;
    }
  }

  @media (min-width: 1024px) {
    .corelink-footer-grid {
      grid-template-columns: repeat(12, 1fr) !important;
      gap: 3rem !important;
    }
  }

  .corelink-footer-col-1 {
    grid-column: span 1 !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-col-1 {
      grid-column: span 4 !important;
    }
  }

  .corelink-footer-col-2,
  .corelink-footer-col-3,
  .corelink-footer-col-4,
  .corelink-footer-col-5 {
    grid-column: span 1 !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-col-2,
    .corelink-footer-col-3,
    .corelink-footer-col-4,
    .corelink-footer-col-5 {
      grid-column: span 2 !important;
    }
  }

  .corelink-footer-logo {
    height: 2.5rem !important;
    margin-bottom: 1rem !important;
    display: block !important;
    max-width: 100% !important;
  }

  .corelink-footer-brand-text {
    color: #4b5563 !important;
    font-size: 0.875rem !important;
    line-height: 1.625 !important;
    margin-bottom: 1.5rem !important;
  }

  .corelink-footer-social-title {
    color: #111827 !important;
    margin-bottom: 0.75rem !important;
    font-size: 0.875rem !important;
    font-weight: 600 !important;
  }

  .corelink-footer-social-links {
    display: flex !important;
    align-items: center !important;
    gap: 0.75rem !important;
  }

  .corelink-footer-social-link {
    width: 2.5rem !important;
    height: 2.5rem !important;
    background-color: #f3f4f6 !important;
    border-radius: 0.5rem !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: all 0.3s !important;
    text-decoration: none !important;
  }

  .corelink-footer-social-link:hover {
    background-color: {{ section.settings.accent_color }} !important;
  }

  .corelink-footer-social-link svg {
    width: 1.25rem !important;
    height: 1.25rem !important;
    color: #4b5563 !important;
    transition: color 0.3s !important;
  }

  .corelink-footer-social-link:hover svg {
    color: #ffffff !important;
  }

  /* Accordion Sections */
  .corelink-footer-col-3,
  .corelink-footer-col-4,
  .corelink-footer-col-5 {
    border-top: 1px solid #e5e7eb !important;
    padding-top: 0.75rem !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-col-3,
    .corelink-footer-col-4,
    .corelink-footer-col-5 {
      border-top: none !important;
      padding-top: 0 !important;
    }
  }

  .corelink-footer-accordion-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100% !important;
    text-align: left !important;
    padding: 0.5rem 0 !important;
    background: none !important;
    border: none !important;
    cursor: pointer !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-accordion-btn {
      pointer-events: none !important;
    }
  }

  .corelink-footer-section-title {
    color: #111827 !important;
    font-weight: 600 !important;
    font-size: 1rem !important;
    margin: 0 !important;
  }

  .corelink-footer-chevron {
    width: 1.25rem !important;
    height: 1.25rem !important;
    color: #4b5563 !important;
    transition: transform 0.3s !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-chevron {
      display: none !important;
    }
  }

  .corelink-footer-chevron.active {
    transform: rotate(180deg) !important;
  }

  .corelink-footer-links {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    margin-top: 1rem !important;
    max-height: 0 !important;
    overflow: hidden !important;
    transition: max-height 0.3s !important;
  }

  @media (min-width: 1024px) {
    .corelink-footer-links {
      display: block !important;
      max-height: none !important;
    }
  }

  .corelink-footer-links.active {
    max-height: 24rem !important;
  }

  .corelink-footer-links li {
    margin: 0 0 0.75rem 0 !important;
    padding: 0 !important;
  }

  .corelink-footer-links li:last-child {
    margin-bottom: 0 !important;
  }

  .corelink-footer-links a,
  .corelink-footer-links span {
    color: #4b5563 !important;
    font-size: 0.875rem !important;
    text-decoration: none !important;
    transition: color 0.3s !important;
    display: block !important;
  }

  .corelink-footer-links a:hover {
    color: {{ section.settings.accent_color }} !important;
  }

  .corelink-footer-contact-item {
    display: flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
    color: #4b5563 !important;
    font-size: 0.875rem !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .corelink-footer-contact-item svg {
    width: 1rem !important;
    height: 1rem !important;
    color: {{ section.settings.accent_color }} !important;
    flex-shrink: 0 !important;
  }

  /* Bottom Bar */
  .corelink-footer-bottom {
    border-top: 1px solid #e5e7eb !important;
    background-color: #f9fafb !important;
  }

  .corelink-footer-bottom-content {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 1.25rem 1.5rem !important;
  }

  .corelink-footer-bottom-grid {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 1rem !important;
  }

  @media (min-width: 768px) {
    .corelink-footer-bottom-grid {
      flex-direction: row !important;
    }
  }

  .corelink-footer-copyright {
    color: #4b5563 !important;
    font-size: 0.875rem !important;
    margin: 0 !important;
  }

  .corelink-footer-bottom-links {
    display: flex !important;
    align-items: center !important;
    gap: 1.5rem !important;
    font-size: 0.875rem !important;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .corelink-footer-bottom-links a {
    color: #4b5563 !important;
    text-decoration: none !important;
    transition: color 0.3s !important;
  }

  .corelink-footer-bottom-links a:hover {
    color: {{ section.settings.accent_color }} !important;
  }
</style>

<div class="corelink-footer-wrapper">
  <footer>
    <!-- Newsletter Section -->
    {% if section.settings.show_newsletter %}
    <div class="corelink-newsletter-section">
      <div class="corelink-newsletter-box">
        <!-- Decorative elements -->
        <div class="corelink-newsletter-deco1"></div>
        <div class="corelink-newsletter-deco2"></div>
        
        <div class="corelink-newsletter-grid">
          <!-- Left side - Illustration -->
          <div class="corelink-newsletter-icon">
            <div class="corelink-newsletter-icon-wrapper">
              <div class="corelink-newsletter-icon-bg"></div>
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/>
              </svg>
            </div>
          </div>

          <!-- Right side - Newsletter content -->
          <div class="corelink-newsletter-content">
            <h2 class="corelink-newsletter-title">
              {{ section.settings.newsletter_title }}
            </h2>
            <p class="corelink-newsletter-desc">
              {{ section.settings.newsletter_description }}
            </p>
            
            <!-- Newsletter Form -->
            <form class="corelink-newsletter-form" action="/contact#newsletter" method="post" accept-charset="UTF-8">
              <input type="hidden" name="form_type" value="customer">
              <input type="hidden" name="utf8" value="✓">
              <input type="hidden" name="contact[tags]" value="newsletter">
              
              <div class="corelink-newsletter-input-wrapper">
                <svg class="corelink-newsletter-input-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                <input 
                  type="email" 
                  name="contact[email]" 
                  placeholder="{{ section.settings.newsletter_placeholder }}" 
                  class="corelink-newsletter-input"
                  required
                />
              </div>
              <button type="submit" class="corelink-newsletter-submit">
                {{ section.settings.newsletter_button_text }}
              </button>
            </form>
            
            <p class="corelink-newsletter-disclaimer">
              {{ section.settings.newsletter_disclaimer }}
              {% if section.settings.privacy_link != blank %}
              <a href="{{ section.settings.privacy_link }}">{{ section.settings.privacy_link_text }}</a>
              {% endif %}
            </p>
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Main Footer Content -->
    <div class="corelink-footer-main-bg">
      <div class="corelink-footer-main">
        <div class="corelink-footer-grid">
          
          <!-- Column 1 - Brand -->
          <div class="corelink-footer-col-1">
            {% if section.settings.logo != blank %}
              <img 
                src="{{ section.settings.logo | img_url: '200x' }}" 
                alt="{{ shop.name }}" 
                class="corelink-footer-logo"
              />
            {% else %}
              <img 
                src="https://cdn.shopify.com/s/files/1/0745/7505/2971/files/Diseno_sin_titulo_9.svg?v=1767416974" 
                alt="{{ shop.name }}" 
                class="corelink-footer-logo"
              />
            {% endif %}
            <p class="corelink-footer-brand-text">
              {{ section.settings.brand_description }}
            </p>
            
            <!-- Social Media -->
            {% if section.settings.show_social %}
            <div>
              <h4 class="corelink-footer-social-title">{{ section.settings.social_title }}</h4>
              <div class="corelink-footer-social-links">
                {% if section.settings.facebook_url != blank %}
                <a href="{{ section.settings.facebook_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.instagram_url != blank %}
                <a href="{{ section.settings.instagram_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.twitter_url != blank %}
                <a href="{{ section.settings.twitter_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
                  </svg>
                </a>
                {% endif %}
                {% if section.settings.youtube_url != blank %}
                <a href="{{ section.settings.youtube_url }}" class="corelink-footer-social-link" target="_blank" rel="noopener">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/>
                    <path d="m10 15 5-3-5-3z"/>
                  </svg>
                </a>
                {% endif %}
              </div>
            </div>
            {% endif %}
          </div>

          <!-- Column 2 - Menu 1 -->
          <div class="corelink-footer-col-2">
            <button class="corelink-footer-accordion-btn" onclick="toggleFooterSection(this, 'menu1')">
              <h3 class="corelink-footer-section-title">{{ section.settings.menu1_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-links" data-section="menu1">
              {% for link in linklists[section.settings.menu1].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <!-- Column 3 - Menu 2 -->
          <div class="corelink-footer-col-3">
            <button class="corelink-footer-accordion-btn" onclick="toggleFooterSection(this, 'menu2')">
              <h3 class="corelink-footer-section-title">{{ section.settings.menu2_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-links" data-section="menu2">
              {% for link in linklists[section.settings.menu2].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <!-- Column 4 - Menu 3 -->
          <div class="corelink-footer-col-4">
            <button class="corelink-footer-accordion-btn" onclick="toggleFooterSection(this, 'menu3')">
              <h3 class="corelink-footer-section-title">{{ section.settings.menu3_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-links" data-section="menu3">
              {% for link in linklists[section.settings.menu3].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <!-- Column 5 - Contact -->
          <div class="corelink-footer-col-5">
            <button class="corelink-footer-accordion-btn" onclick="toggleFooterSection(this, 'contact')">
              <h3 class="corelink-footer-section-title">{{ section.settings.contact_title }}</h3>
              <svg class="corelink-footer-chevron" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <ul class="corelink-footer-links" data-section="contact">
              {% if section.settings.phone != blank %}
              <li class="corelink-footer-contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                <span>{{ section.settings.phone }}</span>
              </li>
              {% endif %}
              {% if section.settings.email != blank %}
              <li class="corelink-footer-contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                <span>{{ section.settings.email }}</span>
              </li>
              {% endif %}
            </ul>
          </div>

        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="corelink-footer-bottom">
      <div class="corelink-footer-bottom-content">
        <div class="corelink-footer-bottom-grid">
          <div class="corelink-footer-copyright">
            {{ section.settings.copyright_text }}
          </div>
          
          <div class="corelink-footer-bottom-links">
            {% for link in linklists[section.settings.bottom_menu].links %}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </footer>
</div>

<script>
  // Accordion functionality for mobile
  function toggleFooterSection(button, sectionId) {
    // Only work on mobile
    if (window.innerWidth >= 1024) return;
    
    var chevron = button.querySelector('.corelink-footer-chevron');
    var links = document.querySelector('.corelink-footer-links[data-section="' + sectionId + '"]');
    
    // Toggle active class
    chevron.classList.toggle('active');
    links.classList.toggle('active');
  }
</script>

