{% schema %}
{
  "name": "Envíos y Devoluciones",
  "tag": "section",
  "class": "shipping-and-returns-section",
  "settings": [
    {
      "type": "header",
      "content": "Configuración de Envíos y Devoluciones"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Título de la Página",
      "default": "Envíos y Devoluciones"
    },
    {
      "type": "textarea",
      "id": "page_description",
      "label": "Descripción de la Página",
      "default": "Conoce nuestras políticas de envío y devoluciones para una experiencia de compra sin preocupaciones."
    },
    {
      "type": "header",
      "content": "Tiempos de Envío"
    },
    {
      "type": "text",
      "id": "santiago_min_days",
      "label": "Santiago - Horas Mínimas",
      "default": "24",
      "info": "Horas hábiles mínimas para envío a Santiago"
    },
    {
      "type": "text",
      "id": "santiago_max_days",
      "label": "Santiago - Horas Máximas",
      "default": "48",
      "info": "Horas hábiles máximas para envío a Santiago"
    },
    {
      "type": "text",
      "id": "regions_min_days",
      "label": "Regiones - Días Mínimos",
      "default": "3",
      "info": "Días hábiles mínimos para envío a regiones"
    },
    {
      "type": "text",
      "id": "regions_max_days",
      "label": "Regiones - Días Máximos",
      "default": "5",
      "info": "Días hábiles máximos para envío a regiones"
    },
    {
      "type": "header",
      "content": "Costos y Devoluciones"
    },
    {
      "type": "text",
      "id": "free_shipping_threshold",
      "label": "Umbral de Envío Gratis",
      "default": "50000",
      "info": "Monto mínimo para envío gratis (en CLP). Dejar en blanco para desactivar."
    },
    {
      "type": "text",
      "id": "return_days",
      "label": "Días para Devoluciones",
      "default": "30",
      "info": "Número de días para aceptar devoluciones (ej. 30)"
    },
    {
      "type": "header",
      "content": "Información de Contacto"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email de Contacto",
      "default": "hello@corelink.cl",
      "info": "Dirección de email para consultas"
    },
    {
      "type": "text",
      "id": "contact_page_url",
      "label": "URL de Página de Contacto",
      "default": "/pages/contact",
      "info": "URL de tu página de contacto (ej. /pages/contact)"
    }
  ],
  "presets": [
    {
      "name": "Envíos y Devoluciones"
    }
  ]
}
{% endschema %}
