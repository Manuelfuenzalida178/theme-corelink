  }
  
  /* Responsive - Large Desktop (1024px+) */
  @media (min-width: 1024px) {
    .lg\:px-8 { padding-left: 2rem; padding-right: 2rem; }
  }
</style>

{% schema %}
{
  "name": "Política de Privacidad",
  "tag": "section",
  "class": "privacy-policy-section",
  "settings": [
    {
      "type": "header",
      "content": "Configuración de Política de Privacidad"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Título de la Página",
      "default": "Política de Privacidad"
    },
    {
      "type": "textarea",
      "id": "page_description",
      "label": "Descripción de la Página",
      "default": "Tu privacidad es importante para nosotros. Aprende cómo recopilamos, usamos y protegemos tu información personal."
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email de Contacto",
      "default": "hello@corelink.cl",
      "info": "Dirección de email para consultas de privacidad"
    },
    {
      "type": "text",
      "id": "contact_page_url",
      "label": "URL de Página de Contacto",
      "default": "/pages/contact",
      "info": "URL de tu página de contacto (ej. /pages/contact)"
    }
  ],
  "presets": [
    {
      "name": "Política de Privacidad"
    }
  ]
}
{% endschema %}
