{% comment %}
  Hero Section with Stats
  - Gradient background with glow effects
  - Editable badge, title, subtitle
  - Stats blocks with icons
  - Fully customizable from Theme Customizer
{% endcomment %}

<style>
  .hero-stats-{{ section.id }} {
    all: initial;
    display: block;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    width: 100%;
  }
  
  .hero-stats-{{ section.id }} *,
  .hero-stats-{{ section.id }} *::before,
  .hero-stats-{{ section.id }} *::after {
    box-sizing: border-box;
  }
  
  .hero-stats-{{ section.id }} .hs-wrapper {
    position: relative;
    overflow: hidden;
    display: block;
    width: 100%;
  }
  
  .hero-stats-{{ section.id }} .hs-gradient-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, #F9FAFB, #F3F4F6, #F9FAFB);
  }
  
  .hero-stats-{{ section.id }} .hs-glow {
    position: absolute;
    width: 384px;
    height: 384px;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.1;
    pointer-events: none;
  }
  
  .hero-stats-{{ section.id }} .hs-glow-1 {
    top: 0;
    left: 25%;
  }
  
  .hero-stats-{{ section.id }} .hs-glow-2 {
    bottom: 0;
    right: 25%;
  }
  
  .hero-stats-{{ section.id }} .hs-container {
    position: relative;
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1rem;
    width: 100%;
  }
  
  .hero-stats-{{ section.id }} .hs-content {
    text-align: center;
    width: 100%;
  }
  
  .hero-stats-{{ section.id }} .hs-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
    border-width: 1px;
    border-style: solid;
  }
  
  .hero-stats-{{ section.id }} .hs-badge svg {
    width: 0.875rem;
    height: 0.875rem;
    display: block;
    flex-shrink: 0;
  }
  
  .hero-stats-{{ section.id }} .hs-badge-text {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 400;
    line-height: 1;
    display: block;
  }
  
  .hero-stats-{{ section.id }} .hs-title {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    color: #111827;
    line-height: 1.1;
    font-weight: 700;
    display: block;
    margin-top: 0;
  }
  
  @media (min-width: 768px) {
    .hero-stats-{{ section.id }} .hs-title {
      font-size: 3rem;
    }
  }
  
  .hero-stats-{{ section.id }} .hs-title br {
    display: block;
  }
  
  .hero-stats-{{ section.id }} .hs-subtitle {
    font-size: 1rem;
    color: #4B5563;
    margin-bottom: 2rem;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
    font-weight: 400;
    display: block;
  }
  
  @media (min-width: 768px) {
    .hero-stats-{{ section.id }} .hs-subtitle {
      font-size: 1.125rem;
    }
  }
  
  .hero-stats-{{ section.id }} .hs-stats {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 3rem);
    text-align: center;
    width: 100%;
  }
  
  .hero-stats-{{ section.id }} .hs-stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 1;
    min-width: 0;
  }
  
  .hero-stats-{{ section.id }} .hs-stat-icon {
    width: clamp(1.5rem, 4vw, 2.5rem);
    height: clamp(1.5rem, 4vw, 2.5rem);
    margin: 0 auto 0.5rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .hero-stats-{{ section.id }} .hs-stat-icon svg {
    width: clamp(0.875rem, 2.5vw, 1.25rem);
    height: clamp(0.875rem, 2.5vw, 1.25rem);
    display: block;
    flex-shrink: 0;
  }
  
  .hero-stats-{{ section.id }} .hs-stat-value {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    margin-bottom: 0.25rem;
    color: #111827;
    font-weight: 600;
    line-height: 1;
    display: block;
    white-space: nowrap;
  }
  
  .hero-stats-{{ section.id }} .hs-stat-label {
    font-size: clamp(0.625rem, 1.5vw, 0.75rem);
    color: #6B7280;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 400;
    line-height: 1;
    display: block;
    white-space: nowrap;
  }
  
  .hero-stats-{{ section.id }} .hs-divider {
    display: none;
  }
  
  @media (min-width: 640px) {
    .hero-stats-{{ section.id }} .hs-divider {
      display: block;
      width: 1px;
      height: clamp(2rem, 5vw, 3rem);
      background-color: #D1D5DB;
      flex-shrink: 0;
    }
  }
</style>

<div class="hero-stats-{{ section.id }}">
  <div class="hs-wrapper" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    
    {%- comment -%} Background gradient {%- endcomment -%}
    <div class="hs-gradient-bg"></div>
    
    {%- comment -%} Glow effects {%- endcomment -%}
    {%- if section.settings.show_glow_effects -%}
      <div class="hs-glow hs-glow-1" style="background-color: {{ section.settings.accent_color }};"></div>
      <div class="hs-glow hs-glow-2" style="background-color: {{ section.settings.accent_color }};"></div>
    {%- endif -%}
    
    <div class="hs-container">
      <div class="hs-content">
        
        {%- comment -%} Badge {%- endcomment -%}
        {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
          <div class="hs-badge" style="background-color: {{ section.settings.badge_bg_color }}; border-color: {{ section.settings.badge_border_color }};">
            {%- if section.settings.badge_icon != 'none' -%}
              {%- case section.settings.badge_icon -%}
                {%- when 'lightning' -%}
                  <svg style="color: {{ section.settings.accent_color }};" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
                  </svg>
                {%- when 'star' -%}
                  <svg style="color: {{ section.settings.accent_color }};" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                {%- when 'fire' -%}
                  <svg style="color: {{ section.settings.accent_color }};" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd" />
                  </svg>
                {%- when 'sparkles' -%}
                  <svg style="color: {{ section.settings.accent_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                  </svg>
              {%- endcase -%}
            {%- endif -%}
            <span class="hs-badge-text" style="color: {{ section.settings.accent_color }};">{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}
        
        {%- comment -%} Title {%- endcomment -%}
        {%- if section.settings.title != blank -%}
          <h1 class="hs-title">
            {{ section.settings.title | newline_to_br }}
          </h1>
        {%- endif -%}
        
        {%- comment -%} Subtitle {%- endcomment -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="hs-subtitle">
            {{ section.settings.subtitle }}
          </p>
        {%- endif -%}
        
        {%- comment -%} Stats {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <div class="hs-stats">
            {%- for block in section.blocks -%}
              {%- if block.type == 'stat' -%}
                
                {%- unless forloop.first -%}
                  <div class="hs-divider"></div>
                {%- endunless -%}
                
                <div class="hs-stat-item" {{ block.shopify_attributes }}>
                  <div class="hs-stat-icon" style="background-color: {{ section.settings.stat_icon_bg_color }};">
                    {%- case block.settings.icon -%}
                      {%- when 'lightning' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                      {%- when 'device' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9h6v6H9z" />
                        </svg>
                      {%- when 'refresh' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                      {%- when 'shield' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                      {%- when 'check' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                      {%- when 'clock' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                      {%- when 'star' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      {%- when 'wifi' -%}
                        <svg style="color: {{ section.settings.accent_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />
                        </svg>
                    {%- endcase -%}
                  </div>
                  <div class="hs-stat-value">{{ block.settings.value }}</div>
                  <div class="hs-stat-label">{{ block.settings.label }}</div>
                </div>
                
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
        
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero con Estadísticas",
  "tag": "section",
  "class": "section-hero-stats",
  "settings": [
    {
      "type": "header",
      "content": "Configuración General"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 64
    },
    {
      "type": "header",
      "content": "Colores y Efectos"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de Acento",
      "default": "#0066FF"
    },
    {
      "type": "checkbox",
      "id": "show_glow_effects",
      "label": "Mostrar Efectos de Resplandor",
      "default": true
    },
    {
      "type": "color",
      "id": "stat_icon_bg_color",
      "label": "Fondo de Iconos de Stats",
      "default": "rgba(0, 102, 255, 0.1)"
    },
    {
      "type": "header",
      "content": "Badge Superior"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Mostrar Badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texto del Badge",
      "default": "Nueva Generación"
    },
    {
      "type": "select",
      "id": "badge_icon",
      "label": "Icono del Badge",
      "options": [
        {
          "value": "none",
          "label": "Sin icono"
        },
        {
          "value": "lightning",
          "label": "Rayo"
        },
        {
          "value": "star",
          "label": "Estrella"
        },
        {
          "value": "fire",
          "label": "Fuego"
        },
        {
          "value": "sparkles",
          "label": "Destellos"
        }
      ],
      "default": "lightning"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Fondo del Badge",
      "default": "rgba(0, 102, 255, 0.1)"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Borde del Badge",
      "default": "rgba(0, 102, 255, 0.3)"
    },
    {
      "type": "header",
      "content": "Contenido Principal"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Título Principal",
      "default": "Cybertruck 3-in-1\nWireless Charger"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "El futuro de la carga inalámbrica con rotacin motorizada y tecnología MagSafe de 15W."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estadística",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            {
              "value": "lightning",
              "label": "Rayo (Energía)"
            },
            {
              "value": "device",
              "label": "Dispositivo"
            },
            {
              "value": "refresh",
              "label": "Rotación"
            },
            {
              "value": "shield",
              "label": "Escudo (Garantía)"
            },
            {
              "value": "check",
              "label": "Check"
            },
            {
              "value": "clock",
              "label": "Reloj"
            },
            {
              "value": "star",
              "label": "Estrella"
            },
            {
              "value": "wifi",
              "label": "WiFi/Wireless"
            }
          ],
          "default": "lightning"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Valor/Número",
          "default": "15W"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "MagSafe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero con Estadísticas",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "icon": "lightning",
            "value": "15W",
            "label": "MagSafe"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "device",
            "value": "3-in-1",
            "label": "Dispositivos"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "refresh",
            "value": "360°",
            "label": "Rotación"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "shield",
            "value": "2 Años",
            "label": "Garantía"
          }
        }
      ]
    }
  ]
}
{% endschema %}