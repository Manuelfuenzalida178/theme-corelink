<script>
(function() {
  'use strict';
  
  const CONFIG = {
    projectId: 'jekitpfjinrixstgeael',
    anonKey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impla2l0cGZqaW5yaXhzdGdlYWVsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjA1NTE3MDMsImV4cCI6MjA3NjEyNzcwM30.eGZAC5LFlCLnVNMHWuiA6Ch_TVAs_1OaGmutKXfwMWA'
  };
  
  const API_URL = `https://${CONFIG.projectId}.supabase.co/functions/v1/make-server-a51ef1fd/reviews/approved`;
  const REVIEWS_PER_PAGE = 12;
  
  let allReviews = [];
  let displayedReviews = 0;
  let lightbox = null;
  let likedReviews = {};
  
  // 🔍 DEBUG: Función para logging detallado
  function debugLog(message, data) {
    console.log(`🔵 [AirPure Widget] ${message}`, data || '');
  }
  
  function renderStars(rating, className = 'airpure-card-star') {
    return Array.from({length: 5}, (_, i) => {
      const filled = i < rating;
      return `
        <svg class="${className}" viewBox="0 0 20 20" fill="${filled ? '#fbbf24' : '#d1d5db'}">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      `;
    }).join('');
  }
  
  function openLightbox(review) {
    if (lightbox) lightbox.remove();
    
    const date = new Date(review.created_at).toLocaleDateString('es-ES', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    });
    
    const isLiked = likedReviews[review.id] || false;
    const helpfulCount = (review.helpfulCount || 0) + (isLiked ? 1 : 0);
    
    lightbox = document.createElement('div');
    lightbox.className = 'airpure-lightbox';
    lightbox.innerHTML = `
      <div class="airpure-lightbox-content">
        <div class="airpure-lightbox-close">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </div>
        
        <div class="airpure-lightbox-image-side">
          ${review.has_photo && review.photoUrl ? `
            <img src="${review.photoUrl}" alt="${review.name}" class="airpure-lightbox-image" 
                 onerror="console.error('Error cargando imagen:', this.src); this.parentElement.style.display='none';" />
            <div class="airpure-lightbox-image-overlay"></div>
            <div class="airpure-lightbox-image-info">
              <div class="airpure-lightbox-verified-badge">
                <div class="airpure-lightbox-verified-icon">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="#2563eb">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="airpure-lightbox-verified-text">COMPRA VERIFICADA</span>
              </div>
              <div class="airpure-stars">
                ${renderStars(review.rating, 'airpure-star')}
              </div>
            </div>
          ` : ''}
        </div>
        
        <div class="airpure-lightbox-body">
          <div class="airpure-lightbox-header">
            <div class="airpure-lightbox-name">${review.name}</div>
            <div class="airpure-lightbox-meta">
              <div class="airpure-lightbox-meta-item">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                </svg>
                <span>${date}</span>
              </div>
              <div class="airpure-lightbox-meta-dot"></div>
              <div class="airpure-lightbox-meta-item">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/>
                </svg>
                <span>Envío verificado</span>
              </div>
            </div>
          </div>
          
          <div class="airpure-lightbox-comment">${review.comment}</div>
          
          ${review.admin_response ? `
            <div class="airpure-admin-response" style="margin-top: 24px;">
              <div class="airpure-admin-label">Respuesta de AirPure</div>
              <div class="airpure-admin-text">${review.admin_response}</div>
            </div>
          ` : ''}
          
          <div class="airpure-lightbox-footer">
            <div class="airpure-lightbox-helpful">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="#2563eb">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span>
                <span class="airpure-lightbox-helpful-count">${helpfulCount}</span>
                personas encontraron esto útil
              </span>
            </div>
            
            <div class="airpure-lightbox-actions">
              <button class="airpure-lightbox-btn airpure-lightbox-btn-like ${isLiked ? 'liked' : ''}" data-review-id="${review.id}">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="${isLiked ? 'white' : 'currentColor'}">
                  <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z"/>
                </svg>
                ${isLiked ? 'Marcado como útil' : 'Marcar como útil'}
              </button>
            </div>
            
            <div class="airpure-lightbox-trust-badge">
              <div class="airpure-lightbox-trust-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="white">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="airpure-lightbox-trust-text">
                <div class="airpure-lightbox-trust-title">Reseña 100% Verificada</div>
                <div class="airpure-lightbox-trust-desc">Cliente real con compra confirmada</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    `;
    
    document.body.appendChild(lightbox);
    
    const closeBtn = lightbox.querySelector('.airpure-lightbox-close');
    closeBtn.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });
    
    const likeBtn = lightbox.querySelector('.airpure-lightbox-btn-like');
    if (likeBtn) {
      likeBtn.addEventListener('click', function() {
        const reviewId = this.getAttribute('data-review-id');
        likedReviews[reviewId] = !likedReviews[reviewId];
        closeLightbox();
        openLightbox(review);
      });
    }
    
    setTimeout(() => lightbox.classList.add('active'), 10);
    document.body.style.overflow = 'hidden';
  }
  
  function closeLightbox() {
    if (lightbox) {
      lightbox.classList.remove('active');
      setTimeout(() => {
        lightbox.remove();
        lightbox = null;
        document.body.style.overflow = '';
      }, 300);
    }
  }
  
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && lightbox) closeLightbox();
  });
  
  function renderReviews(reviewsToShow) {
    let html = '';
    
    reviewsToShow.forEach((review) => {
      const date = new Date(review.created_at).toLocaleDateString('es-ES', {
        day: 'numeric',
        month: 'short',
        year: 'numeric'
      });
      
      const hasValidPhoto = !!(review.has_photo && review.photoUrl && review.photoUrl.trim());
      
      html += `
        <div class="airpure-card" data-review-id="${review.id}">
          ${hasValidPhoto ? `
            <div class="airpure-card-image-wrapper">
              <img 
                src="${review.photoUrl}" 
                alt="Reseña de ${review.name}" 
                class="airpure-card-image"
                onerror="console.error('Error cargando imagen:', this.src); this.style.display='none';"
              />
              <div class="airpure-image-overlay">
                <div class="airpure-click-indicator">
                  <svg width="24" height="24" viewBox="0 0 20 20" fill="#2563eb">
                    <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM14 11a1 1 0 011 1v1h1a1 1 0 110 2h-1v1a1 1 0 11-2 0v-1h-1a1 1 0 110-2h1v-1a1 1 0 011-1z"/>
                  </svg>
                </div>
              </div>
              <div class="airpure-verified-badge">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="#2563eb">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          ` : ''}
          
          <div class="airpure-card-content">
            <div class="airpure-card-stars">
              ${renderStars(review.rating)}
            </div>
            <div class="airpure-name">${review.name}</div>
            <div class="airpure-date">${date}</div>
            <div class="airpure-comment">${review.comment}</div>
            <div class="airpure-verified">
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Compra Verificada
            </div>
            
            ${review.admin_response ? `
              <div class="airpure-admin-response">
                <div class="airpure-admin-label">Respuesta de AirPure</div>
                <div class="airpure-admin-text">${review.admin_response}</div>
              </div>
            ` : ''}
          </div>
        </div>
      `;
    });
    
    return html;
  }
  
  function showMoreReviews() {
    const masonryContainer = document.querySelector('.airpure-masonry');
    const loadMoreBtn = document.getElementById('airpure-load-more-btn');
    const showingCount = document.getElementById('airpure-showing-count');
    
    displayedReviews += REVIEWS_PER_PAGE;
    if (displayedReviews > allReviews.length) {
      displayedReviews = allReviews.length;
    }
    
    const reviewsToShow = allReviews.slice(0, displayedReviews);
    masonryContainer.innerHTML = renderReviews(reviewsToShow);
    
    const allCards = masonryContainer.querySelectorAll('.airpure-card');
    allCards.forEach(card => {
      card.addEventListener('click', function() {
        const reviewId = this.getAttribute('data-review-id');
        const review = allReviews.find(r => r.id == reviewId);
        if (review) openLightbox(review);
      });
    });
    
    showingCount.textContent = `Mostrando ${displayedReviews} de ${allReviews.length} reseñas`;
    
    if (displayedReviews >= allReviews.length) {
      loadMoreBtn.style.display = 'none';
    }
  }
  
  async function loadAndRenderReviews() {
    const container = document.getElementById('airpure-reviews-root');
    
    container.innerHTML = `
      <div class="airpure-loading">
        <div class="airpure-spinner"></div>
        <p style="margin-top: 20px;">Cargando reseñas...</p>
      </div>
    `;
    
    try {
      debugLog('Iniciando carga de reseñas...');
      debugLog('URL del API:', API_URL);
      debugLog('Project ID:', CONFIG.projectId);
      
      const response = await fetch(API_URL, {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${CONFIG.anonKey}`,
          'Content-Type': 'application/json'
        }
      });
      
      debugLog('Respuesta HTTP status:', response.status);
      
      if (!response.ok) {
        const errorText = await response.text();
        debugLog('Error HTTP:', errorText);
        throw new Error(`HTTP ${response.status}: ${errorText}`);
      }
      
      const data = await response.json();
      debugLog('Datos recibidos:', {
        total: data.total,
        reviewsCount: data.reviews?.length || 0,
        hasMore: data.hasMore,
        withPhotos: data.withPhotos
      });
      
      // ✅ VERIFICACIÓN MEJORADA
      if (!data.reviews) {
        debugLog('❌ ERROR: data.reviews es undefined o null', data);
        throw new Error('El servidor no devolvió un array de reseñas. Respuesta: ' + JSON.stringify(data));
      }
      
      if (!Array.isArray(data.reviews)) {
        debugLog('❌ ERROR: data.reviews no es un array', typeof data.reviews);
        throw new Error('data.reviews no es un array válido');
      }
      
      if (data.reviews.length === 0) {
        debugLog('⚠️ No hay reseñas aprobadas en la base de datos');
        container.innerHTML = `
          <div class="airpure-error">
            <div class="airpure-error-title">😊 ¡Sé el primero en dejar una reseña!</div>
            <div class="airpure-error-message">Aún no hay reseñas aprobadas para mostrar.</div>
            <div class="airpure-error-details">
              💡 Tip: Ve al panel de administración y aprueba algunas reseñas para que aparezcan aquí.
            </div>
          </div>
        `;
        return;
      }
      
      // ⭐ ORDENAR: FOTOS PRIMERO → RATING DESCENDENTE → FECHA
      allReviews = data.reviews.sort((a, b) => {
        if (a.has_photo && !b.has_photo) return -1;
        if (!a.has_photo && b.has_photo) return 1;
        if (b.rating !== a.rating) return b.rating - a.rating;
        return new Date(b.created_at) - new Date(a.created_at);
      });
      
      debugLog('✅ Reseñas cargadas y ordenadas:', {
        total: allReviews.length,
        conFotos: allReviews.filter(r => r.has_photo).length,
        sinFotos: allReviews.filter(r => !r.has_photo).length
      });
      
      const total = allReviews.length;
      const avgRating = (allReviews.reduce((sum, r) => sum + r.rating, 0) / total).toFixed(1);
      
      const initialReviews = allReviews.slice(0, REVIEWS_PER_PAGE);
      displayedReviews = initialReviews.length;
      
      let html = `
        <div class="airpure-header">
          <div class="airpure-badge">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="#2563eb">
              <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM14 11a1 1 0 011 1v1h1a1 1 0 110 2h-1v1a1 1 0 11-2 0v-1h-1a1 1 0 110-2h1v-1a1 1 0 011-1z"/>
            </svg>
            <span class="airpure-badge-text">Reseñas Verificadas</span>
            <svg width="16" height="16" viewBox="0 0 20 20" fill="#2563eb">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          
          <h2 class="airpure-title">Lo que dicen nuestros clientes</h2>
          
          <p class="airpure-subtitle">
            Miles de personas confían en <strong style="color: #2563eb;">AirPure®</strong> para mejorar su respiración
          </p>
        </div>
        
        <div class="airpure-stats-bar">
          <div class="airpure-stats-content">
            <div class="airpure-rating-section">
              <div class="airpure-rating-details">
                <div class="airpure-stars-row">
                  <div class="airpure-stars">
                    ${renderStars(5, 'airpure-star')}
                  </div>
                  <span class="airpure-average">${avgRating}</span>
                </div>
                <div class="airpure-total-reviews">${total} Reseñas</div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="airpure-masonry">
          ${renderReviews(initialReviews)}
        </div>
        
        ${total > REVIEWS_PER_PAGE ? `
          <div class="airpure-load-more-container">
            <button id="airpure-load-more-btn" class="airpure-load-more-btn">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.586L7.707 9.293a1 1 0 00-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 10.586V7z" clip-rule="evenodd"/>
              </svg>
              Ver más reseñas
            </button>
            <div id="airpure-showing-count" class="airpure-showing-count">
              Mostrando ${displayedReviews} de ${total} reseñas
            </div>
          </div>
        ` : ''}
      `;
      
      container.innerHTML = html;
      
      const cards = container.querySelectorAll('.airpure-card');
      cards.forEach(card => {
        card.addEventListener('click', function() {
          const reviewId = this.getAttribute('data-review-id');
          const review = allReviews.find(r => r.id == reviewId);
          if (review) openLightbox(review);
        });
      });
      
      const loadMoreBtn = document.getElementById('airpure-load-more-btn');
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', showMoreReviews);
      }
      
      debugLog('✅ Widget renderizado exitosamente');
      
    } catch (error) {
      console.error('❌ ERROR CRÍTICO:', error);
      
      container.innerHTML = `
        <div class="airpure-error">
          <div class="airpure-error-title">❌ Error cargando reseñas</div>
          <div class="airpure-error-message">${error.message}</div>
          <div class="airpure-error-details">
            <strong>Detalles técnicos:</strong><br>
            • URL: ${API_URL}<br>
            • Error: ${error.toString()}<br>
            • Timestamp: ${new Date().toISOString()}<br>
            <br>
            <strong>¿Qué hacer?</strong><br>
            1. Abre la consola del navegador (F12)<br>
            2. Busca mensajes con 🔵 [AirPure Widget]<br>
            3. Verifica que tengas reseñas aprobadas en el admin
          </div>
        </div>
      `;
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadAndRenderReviews);
  } else {
    loadAndRenderReviews();
  }
})();
</script>

{% schema %}
{
  "name": "AirPure Reviews Widget",
  "tag": "section",
  "class": "airpure-reviews-section",
  "settings": [
    {
      "type": "header",
      "content": "✅ Widget de Reseñas Optimizado"
    },
    {
      "type": "paragraph",
      "content": "Con debugging mejorado y paginación perfecta"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "AirPure Reviews Widget"
    }
  ]
}
{% endschema %}

<style>
  .airpure-reviews-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>
