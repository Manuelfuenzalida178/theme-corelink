    },
    {
      "type": "text",
      "id": "our_feature_2_title",
      "label": "Título de la Característica 2",
      "default": "Bluetooth Ultra Estable"
    },
    {
      "type": "text",
      "id": "our_feature_2_desc",
      "label": "Descripción de la Característica 2",
      "default": "Conexión sin cortes ni interrupciones"
    },
    {
      "type": "text",
      "id": "our_feature_3_title",
      "label": "Título de la Característica 3",
      "default": "Sin Calentamiento"
    },
    {
      "type": "text",
      "id": "our_feature_3_desc",
      "label": "Descripción de la Característica 3",
      "default": "Tecnología de enfriamiento avanzada"
    },
    {
      "type": "text",
      "id": "our_feature_4_title",
      "label": "Título de la Característica 4",
      "default": "Conexión Instantánea"
    },
    {
      "type": "text",
      "id": "our_feature_4_desc",
      "label": "Descripción de la Característica 4",
      "default": "Listo en menos de 3 segundos"
    },
    {
      "type": "text",
      "id": "our_feature_5_title",
      "label": "Título de la Característica 5",
      "default": "Compatibilidad Total"
    },
    {
      "type": "text",
