    },
    {
      "type": "text",
      "id": "our_feature_6_title",
      "label": "Título de la Característica 6",
      "default": "Garantía Extendida"
    },
    {
      "type": "text",
      "id": "our_feature_6_desc",
      "label": "Descripción de la Característica 6",
      "default": "24 meses de protección completa"
    },
