{%- comment -%} Modal de Búsqueda Moderno {%- endcomment -%}
<div id="searchModal" class="search-modal-overlay">
  <div class="search-modal-container">
    <div class="search-modal-card">
      
      {%- comment -%} Header con input de búsqueda {%- endcomment -%}
      <div class="search-modal-header">
        <svg class="search-modal-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        
        <input 
          type="text" 
          id="searchModalInput"
          class="search-modal-input" 
          placeholder="Buscar productos..."
          aria-label="Buscar productos"
        >
        
        <button 
          type="button"
          class="search-modal-close" 
          onclick="closeSearchModal()"
          aria-label="Cerrar búsqueda"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      {%- comment -%} Contenido: búsquedas populares {%- endcomment -%}
      <div class="search-modal-content">
        <div class="search-modal-section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
          </svg>
          <h3>Búsquedas Populares</h3>
        </div>

        <div class="search-modal-suggestions">
          <button type="button" class="search-modal-suggestion" onclick="performSearch('Masajeador facial')">
            <span>Kit de inicio Airpure</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </button>
          
          <button type="button" class="search-modal-suggestion" onclick="performSearch('Productos para el cabello')">
            <span>Recargas magneticas</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </button>
        </div>
      </div>

      {%- comment -%} Footer con tip {%- endcomment -%}
      <div class="search-modal-footer">
        <p>Presiona <kbd>ESC</kbd> para cerrar</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Funciones del modal de búsqueda
  function openSearchModal() {
    var modal = document.getElementById('searchModal');
    var input = document.getElementById('searchModalInput');
    
    if (modal) {
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
      
      // Auto-focus en el input
      setTimeout(function() {
        if (input) {
          input.focus();
        }
      }, 100);
    }
  }
  
  function closeSearchModal() {
    var modal = document.getElementById('searchModal');
    
    if (modal) {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }
  }
  
  function performSearch(query) {
    window.location.href = '{{ routes.search_url }}?q=' + encodeURIComponent(query);
  }
  
  // Cerrar modal al hacer click fuera
  document.addEventListener('DOMContentLoaded', function() {
    var modal = document.getElementById('searchModal');
    var input = document.getElementById('searchModalInput');
    
    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          closeSearchModal();
        }
      });
    }
    
    // Búsqueda al presionar Enter
    if (input) {
      input.addEventListener('keypress', function(e) {
        if (e.key === 'Enter' && this.value.trim()) {
          performSearch(this.value.trim());
        }
      });
    }
  });
  
  // Cerrar con tecla ESC
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeSearchModal();
    }
  });
</script>

<script>
  // ===== FUNCIONES MENÚ MÓVIL =====
  function openMobileMenu() {
    var overlay = document.getElementById('mobileMenuOverlay');
    if (overlay) {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }
  
  function closeMobileMenu() {
    var overlay = document.getElementById('mobileMenuOverlay');
    if (overlay) {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }
  }
  
  // Conectar el botón del menú hamburguesa
  document.addEventListener('DOMContentLoaded', function() {
    // Cerrar al hacer click en el overlay
    var overlay = document.getElementById('mobileMenuOverlay');
    if (overlay) {
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) {
          closeMobileMenu();
        }
      });
    }
    
    // Conectar el botón hamburguesa
    var menuToggle = document.querySelector('.js-mobile-nav-toggle');
    if (menuToggle) {
      menuToggle.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        openMobileMenu();
      });
    }
  });
</script>

