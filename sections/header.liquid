{% render 'search-drawer' %}

<style>
  /* ===== IMPORTAR FUENTES PROFESIONALES DESDE GOOGLE FONTS ===== */
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
  
  /* ===== RESET TOTAL - ELIMINAR TODOS LOS ESTILOS DE SHOPIFY ===== */
  .vibrosculpt-header,
  .vibrosculpt-header *,
  .vibrosculpt-header *::before,
  .vibrosculpt-header *::after,
  .vibrosculpt-header__wrapper,
  .vibrosculpt-header__wrapper *,
  .vibrosculpt-header__logo-container,
  .vibrosculpt-header__logo-container *,
  .vibrosculpt-header__nav,
  .vibrosculpt-header__nav *,
  .vibrosculpt-header__actions,
  .vibrosculpt-header__actions *,
  .search-modal-overlay,
  .search-modal-overlay *,
  .search-modal-overlay *::before,
  .search-modal-overlay *::after,
  .mobile-menu-overlay,
  .mobile-menu-overlay *,
  .mobile-menu-overlay *::before,
  .mobile-menu-overlay *::after {
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
    -webkit-font-smoothing: antialiased !important;
    -moz-osx-font-smoothing: grayscale !important;
    text-rendering: optimizeLegibility !important;
    font-weight: inherit !important;
  }
  
  /* ===== ESTILOS PROTEGIDOS - NO AFECTADOS POR SHOPIFY ===== */
  header.vibrosculpt-header {
    background: white !important;
    border-bottom: 1px solid #e5e7eb !important;
    font-weight: 400 !important;
  }
  
  div.vibrosculpt-header__wrapper {
    max-width: 1400px !important;
    margin: 0 auto !important;
    padding: 6px 16px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    height: 50px !important;
    position: relative !important;
  }
  
  div.vibrosculpt-header__logo-container {
    display: flex !important;
    align-items: center !important;
    height: 100% !important;
    flex: 0 0 auto !important;
  }
  
  .vibrosculpt-header__logo-wrapper {
    display: flex !important;
    align-items: center !important;
    height: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  
  a.vibrosculpt-header__logo {
    font-size: 17px !important;
    font-weight: 400 !important;
    letter-spacing: -0.025em !important;
    text-decoration: none !important;
    display: flex !important;
    align-items: center !important;
    line-height: 1 !important;
    height: 100% !important;
  }
  
  img.vibrosculpt-header__logo-image {
    display: block !important;
    max-height: 40px !important;
    width: auto !important;
    object-fit: contain !important;
  }
  
  span.vibrosculpt-header__logo-vibro {
    color: black !important;
    font-weight: 400 !important;
  }
  
  nav.vibrosculpt-header__nav {
    display: flex !important;
    align-items: center !important;
    gap: 24px !important;
    position: absolute !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
  }
  
  a.vibrosculpt-header__nav-link {
    font-size: 13px !important;
    font-weight: 500 !important;
    color: black !important;
    text-decoration: none !important;
    letter-spacing: 0.025em !important;
    transition: color 0.2s !important;
    line-height: 1 !important;
    white-space: nowrap !important;
  }
  
  a.vibrosculpt-header__nav-link:hover {
    color: #00D9FF !important;
  }
  
  div.vibrosculpt-header__actions {
    display: flex !important;
    align-items: center !important;
    gap: 16px !important;
  }
  
  button.vibrosculpt-header__icon-btn {
    background: none !important;
    border: none !important;
    color: black !important;
    cursor: pointer !important;
    padding: 0 !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    transition: color 0.2s !important;
    font-weight: 400 !important;
  }
  
  button.vibrosculpt-header__icon-btn:hover {
    color: #00D9FF !important;
  }
  
  button.vibrosculpt-header__icon-btn svg {
    width: 20px !important;
    height: 20px !important;
    stroke-width: 2 !important;
  }
  
  span.vibrosculpt-header__cart-count {
    font-size: 13px !important;
    font-weight: 500 !important;
    letter-spacing: 0.025em !important;
    color: black !important;
    line-height: 1 !important;
  }
  
  span.vibrosculpt-header__cart-count.hide {
    display: none !important;
  }
  
  /* ===== MODAL DE BÚSQUEDA MODERNO ===== */
  .search-modal-overlay {
    position: fixed !important;
    inset: 0 !important;
    z-index: 100 !important;
    display: none !important;
    background-color: rgba(0, 0, 0, 0.6) !important;
    backdrop-filter: blur(4px) !important;
    animation: fadeIn 0.3s ease-out !important;
  }
  
  .search-modal-overlay.active {
    display: block !important;
  }
  
  .search-modal-container {
    position: relative !important;
    width: 100% !important;
    max-width: 48rem !important;
    margin: 0 auto !important;
    padding: 5rem 1rem 0 !important;
    animation: slideDown 0.3s ease-out !important;
  }
  
  .search-modal-card {
    background: white !important;
    border-radius: 1rem !important;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25) !important;
    overflow: hidden !important;
  }
  
  .search-modal-header {
    padding: 1.5rem !important;
    border-bottom: 1px solid #e5e7eb !important;
    display: flex !important;
    align-items: center !important;
    gap: 1rem !important;
  }
  
  .search-modal-icon {
    width: 1.5rem !important;
    height: 1.5rem !important;
    color: #9ca3af !important;
    flex-shrink: 0 !important;
  }
  
  .search-modal-input {
    flex: 1 !important;
    font-size: 1.125rem !important;
    outline: none !important;
    border: none !important;
    color: #111827 !important;
  }
  
  .search-modal-input::placeholder {
    color: #9ca3af !important;
  }
  
  .search-modal-close {
    padding: 0.5rem !important;
    background: none !important;
    border: none !important;
    border-radius: 9999px !important;
    cursor: pointer !important;
    transition: background-color 0.2s !important;
    flex-shrink: 0 !important;
  }
  
  .search-modal-close:hover {
    background-color: #f3f4f6 !important;
  }
  
  .search-modal-close svg {
    width: 1.5rem !important;
    height: 1.5rem !important;
    color: #4b5563 !important;
  }
  
  .search-modal-content {
    padding: 1.5rem !important;
  }
  
  .search-modal-section-title {
    display: flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
    margin-bottom: 1rem !important;
  }
  
  .search-modal-section-title svg {
    width: 1rem !important;
    height: 1rem !important;
    color: #6b7280 !important;
  }
  
  .search-modal-section-title h3 {
    font-size: 0.875rem !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    color: #6b7280 !important;
    margin: 0 !important;
  }
  
  .search-modal-suggestions {
    display: flex !important;
    flex-direction: column !important;
    gap: 0.5rem !important;
  }
  
  .search-modal-suggestion {
    width: 100% !important;
    text-align: left !important;
    padding: 0.75rem 1rem !important;
    border-radius: 0.5rem !important;
    background: none !important;
    border: none !important;
    cursor: pointer !important;
    transition: background-color 0.2s !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
  }
  
  .search-modal-suggestion:hover {
    background-color: #f9fafb !important;
  }
  
  .search-modal-suggestion span {
    color: #374151 !important;
  }
  
  .search-modal-suggestion:hover span {
    color: #111827 !important;
  }
  
  .search-modal-suggestion svg {
    width: 1rem !important;
    height: 1rem !important;
    color: #9ca3af !important;
    opacity: 0 !important;
    transition: opacity 0.2s !important;
  }
  
  .search-modal-suggestion:hover svg {
    opacity: 1 !important;
  }
  
  .search-modal-footer {
    padding: 1rem 1.5rem !important;
    background-color: #f9fafb !important;
    border-top: 1px solid #e5e7eb !important;
    text-align: center !important;
  }
  
  .search-modal-footer p {
    font-size: 0.75rem !important;
    color: #6b7280 !important;
    margin: 0 !important;
  }
  
  .search-modal-footer kbd {
    padding: 0.25rem 0.5rem !important;
    background: white !important;
    border: 1px solid #d1d5db !important;
    border-radius: 0.25rem !important;
    color: #374151 !important;
    font-family: monospace !important;
    font-size: 0.75rem !important;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0 !important;
    }
    to {
      opacity: 1 !important;
    }
  }
  
  @keyframes slideDown {
    from {
      transform: translateY(-1rem) !important;
      opacity: 0 !important;
    }
    to {
      transform: translateY(0) !important;
      opacity: 1 !important;
    }
  }
  
  @media (max-width: 768px) {
    .vibrosculpt-header__nav {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      height: 0 !important;
      overflow: hidden !important;
      position: absolute !important;
      left: -9999px !important;
    }
    
    nav.vibrosculpt-header__nav {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      height: 0 !important;
      overflow: hidden !important;
      position: absolute !important;
      left: -9999px !important;
    }
    
    .vibrosculpt-header__nav-link {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
    }
    
    a.vibrosculpt-header__nav-link {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
    }
    
    .vibrosculpt-header__mobile-toggle {
      display: block !important;
      position: absolute !important;
      left: 16px !important;
      top: 50% !important;
      transform: translateY(-50%) !important;
      z-index: 10 !important;
    }
    
    .vibrosculpt-header__wrapper {
      justify-content: center !important;
      position: relative !important;
    }
    
    .vibrosculpt-header__logo-container {
      position: absolute !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      z-index: 5 !important;
    }
    
    .vibrosculpt-header__actions {
      position: absolute !important;
      right: 16px !important;
      gap: 12px !important;
      z-index: 10 !important;
    }
    
    .vibrosculpt-header__actions .vibrosculpt-header__mobile-toggle {
      display: none !important;
    }
  }
  
  @media (min-width: 769px) {
    .vibrosculpt-header__mobile-toggle {
      display: none !important;
    }
    
    button.vibrosculpt-header__mobile-toggle {
      display: none !important;
    }
    
    .vibrosculpt-header__icon-btn.vibrosculpt-header__mobile-toggle {
      display: none !important;
    }
  }
  
  /* ===== MENÚ MÓVIL LATERAL ===== */
  .mobile-menu-overlay {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    background-color: rgba(0, 0, 0, 0.5) !important;
    z-index: 999 !important;
    opacity: 0 !important;
    visibility: hidden !important;
    transition: opacity 0.3s ease, visibility 0.3s ease !important;
  }
  
  .mobile-menu-overlay.active {
    opacity: 1 !important;
    visibility: visible !important;
  }
  
  .mobile-menu-drawer {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    bottom: 0 !important;
    width: 85% !important;
    max-width: 375px !important;
    background-color: white !important;
    z-index: 1000 !important;
    transform: translateX(-100%) !important;
    transition: transform 0.3s ease !important;
    overflow-y: auto !important;
    display: flex !important;
    flex-direction: column !important;
  }
  
  .mobile-menu-overlay.active .mobile-menu-drawer {
    transform: translateX(0) !important;
  }
  
  .mobile-menu-header {
    position: absolute !important;
    top: 0 !important;
    right: 0 !important;
    z-index: 10 !important;
    padding: 12px !important;
  }
  
  .mobile-menu-close {
    background: rgba(255, 255, 255, 0.9) !important;
    border: none !important;
    padding: 8px !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    border-radius: 50% !important;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1) !important;
  }
  
  .mobile-menu-close svg {
    width: 24px !important;
    height: 24px !important;
    stroke: #111827 !important;
  }
  
  .mobile-menu-promo {
    display: block !important;
    overflow: hidden !important;
    position: relative !important;
    flex-shrink: 0 !important;
  }
  
  .mobile-menu-promo img {
    width: 100% !important;
    height: auto !important;
    display: block !important;
    max-width: 100% !important;
    object-fit: contain !important;
  }
  
  .mobile-menu-promo-title {
    font-size: 28px !important;
    font-weight: 700 !important;
    line-height: 1.2 !important;
    margin-bottom: 12px !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
  }
  
  .mobile-menu-promo-price {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    margin-bottom: 16px !important;
  }
  
  .mobile-menu-promo-old-price {
    font-size: 14px !important;
    text-decoration: line-through !important;
    opacity: 0.8 !important;
  }
  
  .mobile-menu-promo-new-price {
    font-size: 32px !important;
    font-weight: 700 !important;
  }
  
  .mobile-menu-promo-btn {
    background-color: #1d4ed8 !important;
    color: white !important;
    border: none !important;
    padding: 12px 24px !important;
    border-radius: 4px !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    cursor: pointer !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
  }
  
  .mobile-menu-promo-btn svg {
    width: 16px !important;
    height: 16px !important;
  }
  
  .mobile-menu-nav {
    flex: 1 !important;
    padding: 0 !important;
  }
  
  .mobile-menu-link {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 16px 20px !important;
    text-decoration: none !important;
    color: #111827 !important;
    font-size: 15px !important;
    font-weight: 500 !important;
    border-bottom: 1px solid #f3f4f6 !important;
    transition: background-color 0.2s !important;
  }
  
  .mobile-menu-link:hover {
    background-color: #f9fafb !important;
  }
  
  .mobile-menu-link.black-bg {
    background-color: #111827 !important;
    color: white !important;
  }
  
  .mobile-menu-link.black-bg:hover {
    background-color: #1f2937 !important;
  }
  
  .mobile-menu-link svg {
    width: 18px !important;
    height: 18px !important;
    stroke: currentColor !important;
  }
  
  .mobile-menu-section-title {
    padding: 20px 20px 12px !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    color: #9ca3af !important;
    letter-spacing: 0.5px !important;
  }
  
  .mobile-menu-footer {
    padding: 20px 20px 32px !important;
    border-top: 1px solid #e5e7eb !important;
  }
  
  .mobile-menu-social {
    display: flex !important;
    justify-content: center !important;
    gap: 16px !important;
    margin-bottom: 16px !important;
  }
  
  .mobile-menu-social-link {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 40px !important;
    height: 40px !important;
    background-color: #3b82f6 !important;
    border-radius: 50% !important;
    text-decoration: none !important;
    transition: transform 0.2s !important;
  }
  
  .mobile-menu-social-link:hover {
    transform: scale(1.1) !important;
  }
  
  .mobile-menu-social-link svg {
    width: 20px !important;
    height: 20px !important;
    fill: white !important;
  }
  
  .mobile-menu-copyright {
    text-align: center !important;
    font-size: 11px !important;
    color: #6b7280 !important;
  }
</style>

<div data-section-id="{{ section.id }}" data-section-type="header-section" data-header-section>
  <header class="vibrosculpt-header" role="banner">
    <div class="vibrosculpt-header__wrapper">
      
      {%- comment -%} Mobile Menu Toggle - IZQUIERDA {%- endcomment -%}
      <button type="button" 
              class="vibrosculpt-header__icon-btn vibrosculpt-header__mobile-toggle js-mobile-nav-toggle" 
              aria-controls="MobileNav" 
              aria-expanded="false" 
              aria-label="{{ 'layout.navigation.menu' | t }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      
      {%- comment -%} Logo {%- endcomment -%}
      <div class="vibrosculpt-header__logo-container">
        {% if request.page_type == 'index' %}
          <h1 class="vibrosculpt-header__logo-wrapper">
        {% else %}
          <div class="vibrosculpt-header__logo-wrapper">
        {% endif %}
          {% if section.settings.logo %}
            {%- assign img_url = section.settings.logo | img_url: '1x1' | replace: '_1x1.', '.' -%}
            <a href="{{ routes.root_url }}" class="vibrosculpt-header__logo">
              {% capture logo_alt %}{{ section.settings.logo.alt | default: shop.name }}{% endcapture %}
              <img class="vibrosculpt-header__logo-image js"
                   src="{{ section.settings.logo | img_url: '300x300' }}"
                   srcset="{{ img_url }}"
                   data-widths="[180, 360, 540, 720]"
                   data-aspectratio="{{ section.settings.logo.aspect_ratio }}"
                   data-sizes="auto"
                   loading="lazy"
                   width="auto"
                   height="auto"
                   alt="{{ logo_alt | escape }}"
                   style="max-width: {{ section.settings.logo_max_width }}px;">
              <noscript>
                {% capture image_size %}{{ section.settings.logo_max_width | escape }}x{% endcapture %}
                <img src="{{ section.settings.logo | img_url: image_size }}"
                     srcset="{{ section.settings.logo | img_url: image_size }} 1x, {{ section.settings.logo | img_url: image_size, scale: 2 }} 2x"
                     class="vibrosculpt-header__logo-image"
                     loading="lazy"
                     width="auto"
                     height="auto"
                     alt="{{ section.settings.logo.alt | default: shop.name }}"
                     style="max-width: {{ section.settings.logo_max_width }}px;">
              </noscript>
            </a>
          {% else %}
            <a href="{{ routes.root_url }}" class="vibrosculpt-header__logo">
              <span class="vibrosculpt-header__logo-vibro">{{ shop.name }}</span>
            </a>
          {% endif %}
        {% if request.page_type == 'index' %}
          </h1>
        {% else %}
          </div>
        {% endif %}
      </div>
      
      {%- comment -%} Navigation {%- endcomment -%}
      <nav class="vibrosculpt-header__nav" role="navigation" aria-label="Primary navigation">
        {% for link in linklists[section.settings.main_linklist].links %}
          <a href="{{ link.url }}" 
             class="vibrosculpt-header__nav-link"
             {% if link.current %} aria-current="page"{% endif %}>
            {{ link.title | escape | upcase }}
          </a>
        {% endfor %}
      </nav>
      
      {%- comment -%} Actions (Search & Cart) {%- endcomment -%}
      <div class="vibrosculpt-header__actions">
        
        {%- comment -%} Search {%- endcomment -%}
        <button type="button" 
                class="vibrosculpt-header__icon-btn" 
                onclick="openSearchModal()"
                aria-label="{{ 'layout.navigation.search' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
        
        {%- comment -%} Cart {%- endcomment -%}
        <button type="button"
                class="vibrosculpt-header__icon-btn"
                onclick="openCartDrawer()"
                aria-label="{{ 'layout.cart.title' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="21" r="1"></circle>
            <circle cx="19" cy="21" r="1"></circle>
            <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
          </svg>
          <span class="vibrosculpt-header__cart-count{% if cart.item_count == 0 %} hide{% endif %}" 
                id="CartCount" 
                data-cart-count-bubble>
            <span data-cart-count>{{ cart.item_count }}</span>
          </span>
        </button>
        
      </div>
    </div>
  </header>
  
  {%- comment -%} Mobile Navigation {%- endcomment -%}
  <nav class="mobile-nav-wrapper medium-up--hide critical-hidden" role="navigation">
    <ul id="MobileNav" class="mobile-nav">
      {% for link in linklists[section.settings.main_linklist].links %}
        {%- assign outerLoopIndex = forloop.index -%}

        <li class="mobile-nav__item{% unless forloop.last %} border-bottom{% endunless %}">
          {% if link.links != blank %}
            {% capture child_list_handle %}{{ link.handle }}-{{ outerLoopIndex }}{% endcapture %}
            <button type="button" class="btn--link js-toggle-submenu mobile-nav__link{% if link.child_active %} mobile-nav__link--active{% endif %}" data-target="{{ child_list_handle }}" data-level="1" aria-expanded="false">
              <span class="mobile-nav__label">{{ link.title | escape }}</span>
              <div class="mobile-nav__icon">
                {% render 'icon-chevron-right' %}
              </div>
            </button>
            <ul class="mobile-nav__dropdown" data-parent="{{ child_list_handle }}" data-level="2">
              <li class="visually-hidden" tabindex="-1" data-menu-title="2">
                {{- link.title }} {{ 'layout.navigation.menu' | t -}}
              </li>
              <li class="mobile-nav__item border-bottom">
                <div class="mobile-nav__table">
                  <div class="mobile-nav__table-cell mobile-nav__return">
                    <button class="btn--link js-toggle-submenu mobile-nav__return-btn" type="button" aria-expanded="true" aria-label="{{ link.title }}">
                      {% render 'icon-chevron-left' %}
                    </button>
                  </div>
                  <span class="mobile-nav__sublist-link mobile-nav__sublist-header mobile-nav__sublist-header--main-nav-parent">
                    <span class="mobile-nav__label">{{ link.title | escape }}</span>
                  </span>
                </div>
              </li>

              {% for childlink in link.links %}
                <li class="mobile-nav__item{% unless forloop.last %} border-bottom{% endunless %}">
                  {% if childlink.links != blank %}
                    {% capture grandchild_list_handle %}{{ childlink.handle }}-{{ outerLoopIndex }}-{{ forloop.index }}{% endcapture %}
                    <button type="button" class="btn--link js-toggle-submenu mobile-nav__link mobile-nav__sublist-link" data-target="{{ grandchild_list_handle }}" aria-expanded="false">
                      <span class="mobile-nav__label">{{ childlink.title | escape }}</span>
                      <div class="mobile-nav__icon">
                        {% render 'icon-chevron-right' %}
                      </div>
                    </button>
                    <ul class="mobile-nav__dropdown" data-parent="{{ grandchild_list_handle }}" data-level="3">
                      <li class="visually-hidden" tabindex="-1" data-menu-title="3">
                        {{- childlink.title }} {{ 'layout.navigation.menu' | t -}}
                      </li>
                      <li class="mobile-nav__item border-bottom">
                        <div class="mobile-nav__table">
                          <div class="mobile-nav__table-cell mobile-nav__return">
                            <button type="button" class="btn--link js-toggle-submenu mobile-nav__return-btn" data-target="{{ child_list_handle }}" aria-expanded="true" aria-label="{{ childlink.title }}">
                              {% render 'icon-chevron-left' %}
                            </button>
                          </div>
                          <a href="{{ childlink.url }}"
                            class="mobile-nav__sublist-link mobile-nav__sublist-header"
                            {% if childlink.current %} aria-current="page"{% endif %}
                          >
                            <span class="mobile-nav__label">{{ childlink.title | escape }}</span>
                          </a>
                        </div>
                      </li>
                      {% for grandchildlink in childlink.links %}
                        <li class="mobile-nav__item{% unless forloop.last %} border-bottom{% endunless %}">
                          <a href="{{ grandchildlink.url }}"
                            class="mobile-nav__sublist-link"
                            {% if grandchildlink.current %} aria-current="page"{% endif %}
                          >
                            <span class="mobile-nav__label">{{ grandchildlink.title | escape }}</span>
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% else %}
                    <a href="{{ childlink.url }}"
                      class="mobile-nav__sublist-link"
                      {% if childlink.current %} aria-current="page"{% endif %}
                    >
                      <span class="mobile-nav__label">{{ childlink.title | escape }}</span>
                    </a>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% else %}
            <a href="{{ link.url }}"
              class="mobile-nav__link{% if link.active %} mobile-nav__link--active{% endif %}"
              {% if link.current %} aria-current="page"{% endif %}
            >
              <span class="mobile-nav__label">{{ link.title | escape }}</span>
            </a>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </nav>
</div>

