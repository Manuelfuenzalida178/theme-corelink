{% comment %}
  Section: Comparación Antes y Después
  Descripción: Sección de comparación de productos con diseño premium
{% endcomment %}

<style>
  #comparison-section-{{ section.id }} * {
    box-sizing: border-box;
  }
  
  #comparison-section-{{ section.id }} .comparison-container {
    background: linear-gradient(180deg, #ffffff 0%, #f8f9fa 100%);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    position: relative;
  }
  
  #comparison-section-{{ section.id }} .comparison-deco-left {
    position: absolute;
    top: 10%;
    left: -5%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(34,197,94,0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  #comparison-section-{{ section.id }} .comparison-deco-right {
    position: absolute;
    bottom: 10%;
    right: -5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(239,68,68,0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  #comparison-section-{{ section.id }} .comparison-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }
  
  #comparison-section-{{ section.id }} .comparison-header {
    text-align: center;
    margin-bottom: 35px;
  }
  
  #comparison-section-{{ section.id }} .comparison-eyebrow {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 13px;
    color: #22c55e;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 10px;
    font-weight: 600;
  }
  
  #comparison-section-{{ section.id }} .comparison-title {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 44px;
    font-weight: 700;
    color: #000000;
    margin: 0 0 12px 0;
    letter-spacing: -1px;
    line-height: 1.1;
  }
  
  #comparison-section-{{ section.id }} .comparison-subtitle {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    color: #666666;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }
  
  #comparison-section-{{ section.id }} .comparison-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    margin-bottom: 24px;
    align-items: stretch;
  }
  
  #comparison-section-{{ section.id }} .comparison-card {
    background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  #comparison-section-{{ section.id }} .comparison-card-featured {
    box-shadow: 0 10px 40px rgba(34,197,94,0.15), 0 0 0 1px rgba(34,197,94,0.1);
    border: 3px solid #22c55e;
    transform: scale(1.02);
  }
  
  #comparison-section-{{ section.id }} .comparison-card-featured:hover {
    transform: scale(1.02) translateY(-8px);
  }
  
  #comparison-section-{{ section.id }} .comparison-card-regular {
    background: linear-gradient(135deg, #ffffff 0%, #f9f9f9 100%);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 2px solid #e5e5e5;
  }
  
  #comparison-section-{{ section.id }} .comparison-badge {
    position: absolute;
    top: 20px;
    right: 20px;
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    color: #ffffff;
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 11px;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    z-index: 10;
    box-shadow: 0 4px 12px rgba(34,197,94,0.4);
    border: 2px solid #ffffff;
  }
  
  #comparison-section-{{ section.id }} .comparison-image-wrapper {
    width: 100%;
    height: 240px;
    display: flex;
    align-items: center;
    justif-content: center;
    overflow: hidden;
    position: relative;
  }
  
  #comparison-section-{{ section.id }} .comparison-image-wrapper-featured {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  }
  
  #comparison-section-{{ section.id }} .comparison-image-wrapper-regular {
    background: linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%);
  }
  
  #comparison-section-{{ section.id }} .comparison-image-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(34,197,94,0.2) 0%, transparent 70%);
    border-radius: 50%;
  }
  
  #comparison-section-{{ section.id }} .comparison-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: relative;
    z-index: 1;
  }
  
  #comparison-section-{{ section.id }} .comparison-image-featured {
    filter: drop-shadow(0 8px 16px rgba(0,0,0,0.1));
  }
  
  #comparison-section-{{ section.id }} .comparison-image-regular {
    filter: none;
  }
  
  #comparison-section-{{ section.id }} .comparison-content {
    padding: 28px 28px 32px 28px;
  }
  
  #comparison-section-{{ section.id }} .comparison-content-header {
    margin-bottom: 24px;
  }
  
  #comparison-section-{{ section.id }} .comparison-product-title {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 8px 0;
    letter-spacing: -0.7px;
  }
  
  #comparison-section-{{ section.id }} .comparison-product-title-featured {
    background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  #comparison-section-{{ section.id }} .comparison-product-title-regular {
    color: #999999;
  }
  
  #comparison-section-{{ section.id }} .comparison-product-subtitle {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 14px;
    margin: 0;
    line-height: 1.4;
  }
  
  #comparison-section-{{ section.id }} .comparison-product-subtitle-featured {
    color: #22c55e;
    font-weight: 600;
  }
  
  #comparison-section-{{ section.id }} .comparison-product-subtitle-regular {
    color: #999999;
    font-weight: 500;
  }
  
  #comparison-section-{{ section.id }} .comparison-features {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  
  #comparison-section-{{ section.id }} .comparison-feature {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    border-radius: 12px;
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-positive {
    background: rgba(34,197,94,0.05);
    border: 1px solid rgba(34,197,94,0.1);
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-negative {
    background: rgba(239,68,68,0.04);
    border: 1px solid rgba(239,68,68,0.08);
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-icon {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-icon-positive {
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-icon-negative {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3);
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-text {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 16px;
    line-height: 1.3;
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-text-positive {
    color: #000000;
    font-weight: 600;
  }
  
  #comparison-section-{{ section.id }} .comparison-feature-text-negative {
    color: #666666;
    font-weight: 500;
  }
  
  #comparison-section-{{ section.id }} .comparison-vs-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 30px;
    position: relative;
    z-index: 2;
  }
  
  #comparison-section-{{ section.id }} .comparison-vs-circle {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1a1a 0%, #000000 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2), 0 0 0 4px #ffffff, 0 0 0 6px #e5e5e5;
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 24px;
    font-weight: 900;
    color: #ffffff;
    letter-spacing: 1px;
  }
  
  #comparison-section-{{ section.id }} .comparison-cta {
    text-align: center;
    padding: 28px 28px;
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-radius: 20px;
    box-shadow: 0 8px 24px rgba(34,197,94,0.1);
    border: 2px solid rgba(34,197,94,0.1);
  }
  
  #comparison-section-{{ section.id }} .comparison-cta-title {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #000000;
    margin: 0 0 10px 0;
    letter-spacing: -0.5px;
  }
  
  #comparison-section-{{ section.id }} .comparison-cta-text {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    color: #666666;
    margin: 0;
    line-height: 1.5;
  }
  
  @media (max-width: 767px) {
    #comparison-section-{{ section.id }} .comparison-title {
      font-size: 28px;
    }
    
    #comparison-section-{{ section.id }} .comparison-header {
      margin-bottom: 24px;
    }
    
    #comparison-section-{{ section.id }} .comparison-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }
    
    #comparison-section-{{ section.id }} .comparison-vs-badge {
      display: none;
    }
    
    #comparison-section-{{ section.id }} .comparison-card-featured {
      transform: scale(1);
    }
    
    #comparison-section-{{ section.id }} .comparison-card-featured:hover {
      transform: translateY(-4px);
    }
    
    #comparison-section-{{ section.id }} .comparison-image-wrapper {
      height: 160px;
    }
    
    #comparison-section-{{ section.id }} .comparison-badge {
      top: 12px;
      right: 12px;
      padding: 6px 12px;
      font-size: 10px;
    }
    
    #comparison-section-{{ section.id }} .comparison-content {
      padding: 20px 18px 24px 18px;
    }
    
    #comparison-section-{{ section.id }} .comparison-content-header {
      margin-bottom: 18px;
    }
    
    #comparison-section-{{ section.id }} .comparison-product-title {
      font-size: 22px;
      margin-bottom: 6px;
    }
    
    #comparison-section-{{ section.id }} .comparison-product-subtitle {
      font-size: 13px;
    }
    
    #comparison-section-{{ section.id }} .comparison-features {
      gap: 10px;
    }
    
    #comparison-section-{{ section.id }} .comparison-feature {
      padding: 8px 12px;
      gap: 12px;
    }
    
    #comparison-section-{{ section.id }} .comparison-feature-icon {
      width: 26px;
      height: 26px;
    }
    
    #comparison-section-{{ section.id }} .comparison-feature-icon svg {
      width: 14px;
      height: 14px;
    }
    
    #comparison-section-{{ section.id }} .comparison-feature-text {
      font-size: 14px;
    }
    
    #comparison-section-{{ section.id }} .comparison-cta {
      padding: 22px 20px;
    }
    
    #comparison-section-{{ section.id }} .comparison-cta-title {
      font-size: 18px;
      margin-bottom: 8px;
    }
    
    #comparison-section-{{ section.id }} .comparison-cta-text {
      font-size: 14px;
    }
  }
</style>

<div id="comparison-section-{{ section.id }}">
  <div class="comparison-container">
    <!-- Decorative background elements -->
    <div class="comparison-deco-left"></div>
    <div class="comparison-deco-right"></div>

    <div class="comparison-inner">
      
      <!-- Header -->
      <div class="comparison-header">
        <p class="comparison-eyebrow">{{ section.settings.eyebrow_text }}</p>
        <h2 class="comparison-title">{{ section.settings.title }}</h2>
        <p class="comparison-subtitle">{{ section.settings.subtitle }}</p>
      </div>

      <!-- Comparison Grid -->
      <div class="comparison-grid">

        <!-- Featured Product Column -->
        <div class="comparison-card comparison-card-featured">
          
          <!-- Badge -->
          <div class="comparison-badge">{{ section.settings.featured_badge }}</div>

          <!-- Product Image -->
          <div class="comparison-image-wrapper comparison-image-wrapper-featured">
            <div class="comparison-image-glow"></div>
            {% if section.settings.featured_image != blank %}
              <img 
                src="{{ section.settings.featured_image | img_url: '600x600' }}"
                alt="{{ section.settings.featured_title }}"
                class="comparison-image comparison-image-featured"
                loading="lazy"
              />
            {% else %}
              <img 
                src="https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=600&h=600&fit=crop"
                alt="{{ section.settings.featured_title }}"
                class="comparison-image comparison-image-featured"
                loading="lazy"
              />
            {% endif %}
          </div>

          <!-- Content -->
          <div class="comparison-content">
            <div class="comparison-content-header">
              <h3 class="comparison-product-title comparison-product-title-featured">
                {{ section.settings.featured_title }}
              </h3>
              <p class="comparison-product-subtitle comparison-product-subtitle-featured">
                {{ section.settings.featured_subtitle }}
              </p>
            </div>

            <!-- Features List -->
            <div class="comparison-features">
              {% for block in section.blocks %}
                {% if block.type == 'featured_feature' %}
                  <div class="comparison-feature comparison-feature-positive">
                    <div class="comparison-feature-icon comparison-feature-icon-positive">
                      <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 9L7 13L14 4" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <span class="comparison-feature-text comparison-feature-text-positive">
                      {{ block.settings.text }}
                    </span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

        <!-- VS Badge - Desktop only -->
        <div class="comparison-vs-badge">
          <div class="comparison-vs-circle">VS</div>
        </div>

        <!-- Regular Product Column -->
        <div class="comparison-card comparison-card-regular">
          
          <!-- Product Image -->
          <div class="comparison-image-wrapper comparison-image-wrapper-regular">
            {% if section.settings.regular_image != blank %}
              <img 
                src="{{ section.settings.regular_image | img_url: '600x600' }}"
                alt="{{ section.settings.regular_title }}"
                class="comparison-image comparison-image-regular"
                loading="lazy"
              />
            {% else %}
              <img 
                src="https://images.unsplash.com/photo-1631549916768-4119b2e5f926?w=600&h=600&fit=crop"
                alt="{{ section.settings.regular_title }}"
                class="comparison-image comparison-image-regular"
                loading="lazy"
              />
            {% endif %}
          </div>

          <!-- Content -->
          <div class="comparison-content">
            <div class="comparison-content-header">
              <h3 class="comparison-product-title comparison-product-title-regular">
                {{ section.settings.regular_title }}
              </h3>
              <p class="comparison-product-subtitle comparison-product-subtitle-regular">
                {{ section.settings.regular_subtitle }}
              </p>
            </div>

            <!-- Features List -->
            <div class="comparison-features">
              {% for block in section.blocks %}
                {% if block.type == 'regular_feature' %}
                  <div class="comparison-feature comparison-feature-negative">
                    <div class="comparison-feature-icon comparison-feature-icon-negative">
                      <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <line x1="5" y1="5" x2="12" y2="12" stroke="#ffffff" stroke-width="3" stroke-linecap="round" />
                        <line x1="12" y1="5" x2="5" y2="12" stroke="#ffffff" stroke-width="3" stroke-linecap="round" />
                      </svg>
                    </div>
                    <span class="comparison-feature-text comparison-feature-text-negative">
                      {{ block.settings.text }}
                    </span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

      </div>

      <!-- Bottom CTA -->
      <div class="comparison-cta">
        <h3 class="comparison-cta-title">{{ section.settings.cta_title }}</h3>
        <p class="comparison-cta-text">{{ section.settings.cta_text }}</p>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Comparación Antes/Después",
  "tag": "section",
  "class": "section-comparison",
  "settings": [
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Espacio superior",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Espacio inferior",
      "default": 50
    },
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Texto superior",
      "default": "La Diferencia es Clara"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "AirPure vs Bandas Nasales"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Descubre por qué miles eligen tecnología avanzada sobre soluciones tradicionales"
    },
    {
      "type": "header",
      "content": "Producto Destacado (Izquierda)"
    },
    {
      "type": "text",
      "id": "featured_badge",
      "label": "Texto del badge",
      "default": "⭐ Recomendado"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Imagen del producto destacado"
    },
    {
      "type": "text",
      "id": "featured_title",
      "label": "Nombre del producto",
      "default": "AirPure™"
    },
    {
      "type": "text",
      "id": "featured_subtitle",
      "label": "Subtítulo del producto",
      "default": "Tecnología avanzada de respiración"
    },
    {
      "type": "header",
      "content": "Producto Regular (Derecha)"
    },
    {
      "type": "image_picker",
      "id": "regular_image",
      "label": "Imagen del producto regular"
    },
    {
      "type": "text",
      "id": "regular_title",
      "label": "Nombre del producto",
      "default": "Bandas Nasales"
    },
    {
      "type": "text",
      "id": "regular_subtitle",
      "label": "Subtítulo del producto",
      "default": "Tiras adhesivas tradicionales"
    },
    {
      "type": "header",
      "content": "Call to Action Final"
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "Título del CTA",
      "default": "Únete a +10,000 personas que respiran mejor"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "Texto del CTA",
      "default": "Prueba AirPure sin riesgo con nuestra garantía de satisfacción de 30 días"
    }
  ],
  "blocks": [
    {
      "type": "featured_feature",
      "name": "Característica Destacada",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Característica positiva"
        }
      ]
    },
    {
      "type": "regular_feature",
      "name": "Característica Regular",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Característica negativa"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparación Antes/Después",
      "blocks": [
        {
          "type": "featured_feature",
          "settings": {
            "text": "Dilatación superior"
          }
        },
        {
          "type": "featured_feature",
          "settings": {
            "text": "Permanece toda la noche"
          }
        },
        {
          "type": "featured_feature",
          "settings": {
            "text": "Ajuste de precisión"
          }
        },
        {
          "type": "featured_feature",
          "settings": {
            "text": "Protege la piel sensible"
          }
        },
        {
          "type": "regular_feature",
          "settings": {
            "text": "Endebles"
          }
        },
        {
          "type": "regular_feature",
          "settings": {
            "text": "Se caen"
          }
        },
        {
          "type": "regular_feature",
          "settings": {
            "text": "Esperas que se ajusten"
          }
        },
        {
          "type": "regular_feature",
          "settings": {
            "text": "Arranca la piel del puente nasal"
          }
        }
      ]
    }
  ]
}
{% endschema %}
