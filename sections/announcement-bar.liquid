{% comment %}
  Announcement Bar con animación marquee
{% endcomment %}

<style>
  .announcement-bar {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 8px 0;
    overflow: hidden;
    position: relative;
    width: 100%;
  }
  
  .announcement-bar__marquee {
    white-space: nowrap;
    animation: marquee {{ section.settings.animation_speed }}s linear infinite;
    display: inline-block;
  }
  
  .announcement-bar__text {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
  }
  
  .announcement-bar__separator {
    margin: 0 32px;
    display: inline-block;
  }
  
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  
  /* Pausar animación al hover */
  .announcement-bar:hover .announcement-bar__marquee {
    animation-play-state: paused;
  }
</style>

{%- liquid
  assign bar_message = section.settings.message_mundial
  assign market = localization.market.handle
  assign locale = request.locale.iso_code

  if market == 'chile' or market == 'cl'
    assign bar_message = section.settings.message_chile
  elsif locale == 'en'
    assign bar_message = section.settings.message_english
  elsif market contains 'chile'
    assign bar_message = section.settings.message_chile
  endif
-%}

<div class="announcement-bar">
  <div class="announcement-bar__marquee">
    {% comment %} Repetir el mensaje 8 veces para efecto continuo {% endcomment %}
    {% for i in (1..8) %}
      <span class="announcement-bar__text">
        {{ bar_message | escape }}
      </span>
      {% unless forloop.last %}
        <span class="announcement-bar__separator">•</span>
      {% endunless %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "message_chile",
      "label": "Mensaje Chile",
      "default": "Obtén envío gratis a todo chile"
    },
    {
      "type": "text",
      "id": "message_english",
      "label": "Message English",
      "default": "Free shipping worldwide"
    },
    {
      "type": "text",
      "id": "message_mundial",
      "label": "Mensaje Mundial",
      "default": "Obtén envío gratis + hasta 60% OFF"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#60a5fa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Velocidad de animación (segundos)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30,
      "info": "Mayor número = más lento"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
