{% comment %}
  Feature Section with Media
  - Editable badge, title, description
  - Feature icons as blocks
  - Video or Image support
  - Left/Right media position
  - Adjustable spacing
{% endcomment %}

<style>
  .feature-section-{{ section.id }} * {
    box-sizing: border-box;
  }
  
  .feature-section-{{ section.id }} {
    font-family: 'TT Norms Pro', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  .feature-section-{{ section.id }} .fs-container {
    max-width: 1280px;
    margin: 0 auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  
  .feature-section-{{ section.id }} .fs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  
  @media (min-width: 768px) {
    .feature-section-{{ section.id }} .fs-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }
  }
  
  .feature-section-{{ section.id }} .fs-badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: rgba(0, 102, 255, 0.1);
    color: #0066FF;
  }
  
  .feature-section-{{ section.id }} .fs-title {
    font-size: 1.875rem;
    margin-bottom: 1rem;
    color: #111827;
    line-height: 1.2;
    font-weight: 700;
  }
  
  @media (min-width: 768px) {
    .feature-section-{{ section.id }} .fs-title {
      font-size: 2.25rem;
    }
  }
  
  .feature-section-{{ section.id }} .fs-description {
    font-size: 1rem;
    color: #4B5563;
    margin-bottom: 1.5rem;
    line-height: 1.625;
    font-weight: 400;
  }
  
  .feature-section-{{ section.id }} .fs-features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  @media (min-width: 768px) {
    .feature-section-{{ section.id }} .fs-features {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
  
  .feature-section-{{ section.id }} .fs-feature-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .feature-section-{{ section.id }} .fs-feature-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 102, 255, 0.1);
    flex-shrink: 0;
  }
  
  .feature-section-{{ section.id }} .fs-feature-icon svg {
    width: 1rem;
    height: 1rem;
    color: #0066FF;
  }
  
  .feature-section-{{ section.id }} .fs-feature-text {
    font-size: 0.875rem;
    color: #374151;
    font-weight: 400;
  }
  
  .feature-section-{{ section.id }} .fs-media-wrapper {
    aspect-ratio: 1 / 1;
    border-radius: 1rem;
    overflow: hidden;
    background-color: #F3F4F6;
  }
  
  .feature-section-{{ section.id }} .fs-media-wrapper video,
  .feature-section-{{ section.id }} .fs-media-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .feature-section-{{ section.id }} .fs-order-1 {
    order: 1;
  }
  
  .feature-section-{{ section.id }} .fs-order-2 {
    order: 2;
  }
  
  @media (min-width: 768px) {
    .feature-section-{{ section.id }} .fs-order-md-1 {
      order: 1;
    }
    
    .feature-section-{{ section.id }} .fs-order-md-2 {
      order: 2;
    }
  }
</style>

<div class="feature-section-{{ section.id }}" style="background-color: {{ section.settings.background_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="fs-container">
    <div class="fs-grid">
      
      {%- comment -%} Text Content {%- endcomment -%}
      <div class="fs-order-{{ section.settings.content_order_mobile }} {% if section.settings.media_position == 'left' %}fs-order-md-2{% else %}fs-order-md-1{% endif %}">
        
        {%- if section.settings.badge != blank -%}
          <div class="fs-badge">
            {{ section.settings.badge }}
          </div>
        {%- endif -%}
        
        {%- if section.settings.title != blank -%}
          <h2 class="fs-title">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}
        
        {%- if section.settings.description != blank -%}
          <div class="fs-description">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
        
        {%- if section.settings.show_features and section.blocks.size > 0 -%}
          <div class="fs-features">
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <div class="fs-feature-item" {{ block.shopify_attributes }}>
                  <div class="fs-feature-icon">
                    {%- case block.settings.icon -%}
                      {%- when 'lightning' -%}
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                      {%- when 'refresh' -%}
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                      {%- when 'lightbulb' -%}
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                        </svg>
                      {%- when 'device' -%}
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9h6v6H9z" />
                        </svg>
                      {%- when 'shield' -%}
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                      {%- when 'check' -%}
                        <svg fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                    {%- endcase -%}
                  </div>
                  <span class="fs-feature-text">{{ block.settings.text }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
        
      </div>
      
      {%- comment -%} Media Content {%- endcomment -%}
      <div class="fs-order-{{ section.settings.media_order_mobile }} {% if section.settings.media_position == 'left' %}fs-order-md-1{% else %}fs-order-md-2{% endif %}">
        <div class="fs-media-wrapper">
          {%- if section.settings.media_type == 'video' and section.settings.video_url != blank -%}
            <video autoplay loop muted playsinline>
              <source src="{{ section.settings.video_url }}" type="video/mp4">
            </video>
          {%- elsif section.settings.media_type == 'image' and section.settings.image != blank -%}
            <img 
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                      {{ section.settings.image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | escape }}"
              loading="lazy"
            >
          {%- else -%}
            <div style="width: 100%; height: 100%; background-color: #E5E7EB; display: flex; align-items: center; justify-content: center; color: #9CA3AF; font-size: 0.875rem;">
              Sin media
            </div>
          {%- endif -%}
        </div>
      </div>
      
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Feature Section",
  "tag": "section",
  "class": "section-feature",
  "settings": [
    {
      "type": "header",
      "content": "Configuración General"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de Fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 64
    },
    {
      "type": "header",
      "content": "Contenido de Texto"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge (etiqueta superior)",
      "default": "Innovación en Carga"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Título",
      "default": "Potencia y Estilo.\nRedefinidos."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descripción",
      "default": "<p>Ecosistema de carga inteligente con tecnología MagSafe 15W, rotación motorizada 360° e iluminación LED personalizable.</p>"
    },
    {
      "type": "header",
      "content": "Features con Iconos"
    },
    {
      "type": "checkbox",
      "id": "show_features",
      "label": "Mostrar Features",
      "default": true
    },
    {
      "type": "header",
      "content": "Media (Video o Imagen)"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Tipo de Media",
      "options": [
        {
          "value": "video",
          "label": "Video"
        },
        {
          "value": "image",
          "label": "Imagen"
        }
      ],
      "default": "video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL del Video",
      "info": "URL completa del video MP4",
      "default": "https://evolvedchargers.com/cdn/shop/videos/c/vp/39cd61391ad24b3ea8dc540fabb72337/39cd61391ad24b3ea8dc540fabb72337.HD-1080p-2.5Mbps-61007157.mp4?v=0"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "header",
      "content": "Layout y Posición"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Posición del Media (Desktop)",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "content_order_mobile",
      "label": "Orden del Texto (Móvil)",
      "options": [
        {
          "value": "1",
          "label": "Primero"
        },
        {
          "value": "2",
          "label": "Segundo"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "media_order_mobile",
      "label": "Orden del Media (Móvil)",
      "options": [
        {
          "value": "1",
          "label": "Primero"
        },
        {
          "value": "2",
          "label": "Segundo"
        }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Icon",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            {
              "value": "lightning",
              "label": "Rayo (Energía)"
            },
            {
              "value": "refresh",
              "label": "Rotación"
            },
            {
              "value": "lightbulb",
              "label": "Bombilla (LED)"
            },
            {
              "value": "device",
              "label": "Dispositivo"
            },
            {
              "value": "shield",
              "label": "Escudo (Garantía)"
            },
            {
              "value": "check",
              "label": "Check (Verificado)"
            }
          ],
          "default": "lightning"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto del Feature",
          "default": "Feature text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Section",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "lightning",
            "text": "Carga 3 dispositivos"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "refresh",
            "text": "Rotación motorizada"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "lightbulb",
            "text": "LED ambiental"
          }
        }
      ]
    }
  ]
}
{% endschema %}